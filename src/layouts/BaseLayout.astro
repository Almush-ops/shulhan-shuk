---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  noindex?: boolean;
}

const {
  title,
  description = '',
  ogImage,
  ogType,
  canonicalUrl,
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      canonicalUrl={canonicalUrl}
      noindex={noindex}
    />
  </head>
  <body class="min-h-screen flex flex-col bg-white text-dark antialiased font-sans">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- WhatsApp Floating Button -->
    <button
      id="whatsapp-float"
      class="fixed bottom-6 start-6 z-40 bg-[#25D366] text-white w-14 h-14 rounded-full shadow-lg hover:shadow-xl hover:scale-110 transition-all flex items-center justify-center md:w-16 md:h-16"
      aria-label="צור קשר בוואטסאפ"
    >
      <svg class="w-7 h-7 md:w-8 md:h-8" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </button>

    <!-- WhatsApp Modal -->
    <div id="whatsapp-modal" class="fixed inset-0 z-50 hidden">
      <div class="absolute inset-0 bg-dark/60 backdrop-blur-sm" id="whatsapp-overlay"></div>
      <div class="absolute bottom-24 start-6 w-80 bg-white rounded-2xl shadow-2xl p-6 animate-fade-in">
        <button id="whatsapp-close" class="absolute top-3 end-3 text-muted hover:text-dark transition-colors" aria-label="סגור">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
        <h3 class="text-lg font-bold text-dark mb-1">דברו איתנו בוואטסאפ</h3>
        <p class="text-sm text-muted mb-4">השאירו פרטים ונחזור אליכם מיד</p>
        <form id="whatsapp-form" class="space-y-3">
          <input
            type="text"
            name="wa-name"
            placeholder="שם מלא"
            required
            class="w-full px-4 py-2.5 border border-border rounded-lg text-dark placeholder-muted/60 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-colors"
          />
          <input
            type="tel"
            name="wa-phone"
            placeholder="טלפון"
            required
            dir="ltr"
            class="w-full px-4 py-2.5 border border-border rounded-lg text-dark placeholder-muted/60 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-colors"
          />
          <button
            type="submit"
            class="w-full py-3 bg-[#25D366] text-white font-semibold rounded-lg hover:bg-[#20BD5A] transition-colors flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            שלחו הודעה
          </button>
        </form>
      </div>
    </div>

    <!-- Accessibility Widget -->
    <div id="a11y-widget" class="fixed bottom-6 end-6 z-40">
      <button
        id="a11y-toggle"
        class="bg-dark text-white w-12 h-12 rounded-full shadow-lg hover:shadow-xl hover:scale-110 transition-all flex items-center justify-center"
        aria-label="תפריט נגישות"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5c-4.5 0-7.5 3-7.5 7.5s3 7.5 7.5 7.5 7.5-3 7.5-7.5-3-7.5-7.5-7.5z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5v0M9 11l3 6 3-6M8 11h8" />
        </svg>
      </button>
      <div id="a11y-panel" class="hidden absolute bottom-14 end-0 w-56 bg-white rounded-xl shadow-xl border border-border p-4 space-y-3">
        <p class="text-sm font-bold text-dark mb-2">נגישות</p>
        <button data-a11y="font-up" class="w-full text-start text-sm py-2 px-3 rounded-lg hover:bg-surface transition-colors">הגדל גופן</button>
        <button data-a11y="font-down" class="w-full text-start text-sm py-2 px-3 rounded-lg hover:bg-surface transition-colors">הקטן גופן</button>
        <button data-a11y="grayscale" class="w-full text-start text-sm py-2 px-3 rounded-lg hover:bg-surface transition-colors">גווני אפור</button>
        <button data-a11y="contrast" class="w-full text-start text-sm py-2 px-3 rounded-lg hover:bg-surface transition-colors">ניגודיות גבוהה</button>
        <button data-a11y="links" class="w-full text-start text-sm py-2 px-3 rounded-lg hover:bg-surface transition-colors">הדגש קישורים</button>
        <button data-a11y="reset" class="w-full text-center text-sm py-2 px-3 rounded-lg bg-brand-50 text-brand-700 hover:bg-brand-100 transition-colors font-medium">איפוס</button>
      </div>
    </div>

    <style>
      @keyframes fade-in {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-in {
        animation: fade-in 0.2s ease-out;
      }
    </style>

    <script>
      // WhatsApp popup
      const waBtn = document.getElementById('whatsapp-float');
      const waModal = document.getElementById('whatsapp-modal');
      const waOverlay = document.getElementById('whatsapp-overlay');
      const waClose = document.getElementById('whatsapp-close');
      const waForm = document.getElementById('whatsapp-form') as HTMLFormElement;

      function openWaModal() { waModal?.classList.remove('hidden'); }
      function closeWaModal() { waModal?.classList.add('hidden'); }

      waBtn?.addEventListener('click', openWaModal);
      waOverlay?.addEventListener('click', closeWaModal);
      waClose?.addEventListener('click', closeWaModal);

      waForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const fd = new FormData(waForm);
        const name = fd.get('wa-name') as string;
        const phone = fd.get('wa-phone') as string;

        // TODO: Save lead to Supabase here
        // try {
        //   await fetch('WEBHOOK_URL', {
        //     method: 'POST',
        //     headers: { 'Content-Type': 'application/json' },
        //     body: JSON.stringify({ name, phone, source: 'whatsapp', page: window.location.pathname }),
        //   });
        // } catch {}

        // Redirect to WhatsApp
        const waNumber = '972XXXXXXXXX'; // TBD from client
        const msg = encodeURIComponent(`שלום, שמי ${name}. אשמח לקבל הצעת מחיר לשולחן שוק.`);
        window.open(`https://wa.me/${waNumber}?text=${msg}`, '_blank');
        closeWaModal();
      });

      // Accessibility widget
      const a11yToggle = document.getElementById('a11y-toggle');
      const a11yPanel = document.getElementById('a11y-panel');

      a11yToggle?.addEventListener('click', () => {
        a11yPanel?.classList.toggle('hidden');
      });

      document.querySelectorAll('[data-a11y]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const action = (btn as HTMLElement).dataset.a11y;
          const body = document.body;
          switch (action) {
            case 'font-up':
              const currentUp = parseFloat(getComputedStyle(document.documentElement).fontSize);
              document.documentElement.style.fontSize = `${Math.min(currentUp + 2, 24)}px`;
              break;
            case 'font-down':
              const currentDown = parseFloat(getComputedStyle(document.documentElement).fontSize);
              document.documentElement.style.fontSize = `${Math.max(currentDown - 2, 12)}px`;
              break;
            case 'grayscale':
              body.classList.toggle('a11y-grayscale');
              break;
            case 'contrast':
              body.classList.toggle('a11y-contrast');
              break;
            case 'links':
              body.classList.toggle('a11y-links');
              break;
            case 'reset':
              body.classList.remove('a11y-grayscale', 'a11y-contrast', 'a11y-links');
              document.documentElement.style.fontSize = '';
              break;
          }
        });
      });

      // Close a11y panel on outside click
      document.addEventListener('click', (e) => {
        const widget = document.getElementById('a11y-widget');
        if (widget && !widget.contains(e.target as Node)) {
          a11yPanel?.classList.add('hidden');
        }
      });
    </script>
  </body>
</html>
