---
interface TrustItem {
  value: string;
  label: string;
}

interface Props {
  items?: TrustItem[];
}

const { items = [
  { value: '7+', label: 'שנות ניסיון' },
  { value: '1,000+', label: 'אירועים' },
  { value: '100%', label: 'כיסוי ארצי' },
  { value: '4.9/5', label: 'שביעות רצון' },
] } = Astro.props;
---

<section class="bg-white py-10 md:py-14 border-y border-border/50">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
      {items.map((item) => (
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-bold text-brand-600 font-heading font-bold" dir="ltr">{item.value}</p>
          <p class="text-sm text-muted mt-1">{item.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
