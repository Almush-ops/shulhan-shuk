---
interface Props {
  title?: string;
  subtitle?: string;
  primaryText?: string;
  primaryHref?: string;
  phone?: string;
  backgroundImage?: string;
}

const {
  title = 'מוכנים להזמין שולחן שוק?',
  subtitle = 'צרו קשר עכשיו וקבלו הצעת מחיר תוך שעה',
  primaryText = 'קבלו הצעת מחיר',
  primaryHref = '#hero-contact-form',
  phone,
  backgroundImage = '/images/hero/hero-03.webp',
} = Astro.props;
---

<section class="relative overflow-hidden">
  {backgroundImage && (
    <img
      src={backgroundImage}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
  )}
  <div class="absolute inset-0 bg-brand-900/75"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-4 py-16 md:py-20 text-center text-white">
    <h2 class="text-2xl md:text-3xl font-heading mb-3">{title}</h2>
    <p class="text-brand-100 text-lg mb-8">{subtitle}</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={primaryHref}
        class="inline-flex items-center justify-center px-8 py-4 bg-white text-brand-700 font-bold rounded-lg hover:bg-brand-50 transition-all shadow-lg text-lg"
      >
        {primaryText}
      </a>
      {phone && (
        <a
          href={`tel:${phone}`}
          class="inline-flex items-center justify-center px-8 py-4 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition-colors text-lg gap-2"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {phone}
        </a>
      )}
    </div>
  </div>
</section>
