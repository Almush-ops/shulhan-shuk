---
interface FormField {
  name: string;
  label: string;
  type: 'text' | 'tel' | 'email' | 'select';
  placeholder?: string;
  required?: boolean;
  options?: { value: string; label: string }[];
}

interface Props {
  title: string;
  subtitle?: string;
  formTitle?: string;
  backgroundImage?: string;
  trustItems?: string[];
  formFields?: FormField[];
  submitText?: string;
}

const {
  title,
  subtitle,
  formTitle = 'קבלו הצעת מחיר',
  backgroundImage,
  trustItems,
  formFields = [
    { name: 'name', label: 'שם מלא', type: 'text' as const, placeholder: 'הזינו שם מלא', required: true },
    { name: 'phone', label: 'טלפון', type: 'tel' as const, placeholder: '050-0000000', required: true },
    {
      name: 'event_type', label: 'סוג אירוע', type: 'select' as const, placeholder: 'בחרו סוג אירוע', required: true,
      options: [
        { value: 'birthday', label: 'יום הולדת' },
        { value: 'bar-mitzva', label: 'בר/בת מצווה' },
        { value: 'wedding', label: 'חתונה' },
        { value: 'bachelorette', label: 'מסיבת רווקות' },
        { value: 'henna', label: 'חינה' },
        { value: 'corporate', label: 'אירוע חברה' },
        { value: 'shabbat', label: 'שבת/חג' },
        { value: 'other', label: 'אחר' },
      ],
    },
    {
      name: 'guests', label: 'כמות אורחים', type: 'select' as const, placeholder: 'בחרו כמות', required: true,
      options: [
        { value: '10-20', label: '10-20 אורחים' },
        { value: '20-40', label: '20-40 אורחים' },
        { value: '40-60', label: '40-60 אורחים' },
        { value: '60-100', label: '60-100 אורחים' },
        { value: '100+', label: 'מעל 100 אורחים' },
      ],
    },
  ],
  submitText = 'קבלו הצעת מחיר',
} = Astro.props;
---

<section class="relative overflow-hidden min-h-[600px] md:min-h-[700px] flex items-center">
  <!-- Background image -->
  {backgroundImage ? (
    <img
      src={backgroundImage}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      width="1920"
      height="1080"
      loading="eager"
      fetchpriority="high"
    />
  ) : (
    <div class="absolute inset-0 bg-gradient-to-br from-brand-800 to-brand-900"></div>
  )}

  <!-- Gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-l from-dark/80 via-dark/60 to-dark/40"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 py-20 md:py-28 w-full">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">

      <!-- Text Side -->
      <div class="text-white">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading leading-tight mb-6">
          {title}
        </h1>
        {subtitle && (
          <p class="text-lg md:text-xl text-white/80 leading-relaxed mb-8 max-w-lg">
            {subtitle}
          </p>
        )}

        {trustItems && trustItems.length > 0 && (
          <div class="grid grid-cols-2 gap-3 mt-6">
            {trustItems.map((item) => (
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-fresh-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm text-white/90">{item}</span>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Form Card -->
      <div class="bg-white rounded-2xl shadow-2xl p-6 md:p-8">
        <h2 class="text-xl md:text-2xl font-bold text-dark mb-6 text-center font-heading">
          {formTitle}
        </h2>

        <form id="hero-contact-form" class="space-y-4">
          {formFields.map((field) => (
            <div>
              <label for={`hero-${field.name}`} class="block text-sm font-medium text-dark mb-1.5">
                {field.label}
                {field.required && <span class="text-red-500 ms-0.5">*</span>}
              </label>

              {field.type === 'select' ? (
                <select
                  id={`hero-${field.name}`}
                  name={field.name}
                  required={field.required}
                  class="w-full px-4 py-3 border border-border rounded-lg text-dark bg-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-colors"
                >
                  {field.placeholder && (
                    <option value="" disabled selected>{field.placeholder}</option>
                  )}
                  {field.options?.map((opt) => (
                    <option value={opt.value}>{opt.label}</option>
                  ))}
                </select>
              ) : (
                <input
                  type={field.type}
                  id={`hero-${field.name}`}
                  name={field.name}
                  placeholder={field.placeholder}
                  required={field.required}
                  dir={field.type === 'tel' ? 'ltr' : undefined}
                  class="w-full px-4 py-3 border border-border rounded-lg text-dark placeholder-muted/60 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-colors"
                />
              )}
            </div>
          ))}

          <button
            type="submit"
            class="w-full px-6 py-3.5 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-700 transition-all shadow-md hover:shadow-lg text-lg focus:ring-2 focus:ring-brand-500 focus:ring-offset-2"
          >
            {submitText}
          </button>

          <div id="hero-form-success" class="hidden text-center p-4 bg-fresh-500/10 text-fresh-600 rounded-lg text-sm font-medium">
            הפרטים נשלחו בהצלחה! ניצור קשר בהקדם.
          </div>
          <div id="hero-form-error" class="hidden text-center p-4 bg-red-50 text-red-700 rounded-lg text-sm font-medium">
            אירעה שגיאה. אנא נסו שוב או התקשרו אלינו.
          </div>
        </form>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('hero-contact-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const successDiv = document.getElementById('hero-form-success');
      const errorDiv = document.getElementById('hero-form-error');
      const originalText = submitBtn.textContent;

      submitBtn.disabled = true;
      submitBtn.textContent = 'שולח...';
      successDiv?.classList.add('hidden');
      errorDiv?.classList.add('hidden');

      const formData = new FormData(form);
      const data: Record<string, string> = {};
      formData.forEach((value, key) => { data[key] = value as string; });
      data['page_url'] = window.location.href;
      const h1 = document.querySelector('h1')?.textContent?.trim() || '';
      data['page_title'] = h1;

      try {
        // TODO: Replace with actual webhook URL
        // const response = await fetch('WEBHOOK_URL', {
        //   method: 'POST',
        //   headers: { 'Content-Type': 'application/json' },
        //   body: JSON.stringify(data),
        // });
        // if (!response.ok) throw new Error('Submit failed');

        // Simulate success for now
        await new Promise(resolve => setTimeout(resolve, 500));

        form.reset();
        successDiv?.classList.remove('hidden');
        submitBtn.textContent = originalText;
      } catch {
        errorDiv?.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
  }
</script>
