---
const navItems = [
  {
    label: 'שולחנות',
    href: '#',
    children: [
      { label: 'שולחן שוק בשרי', href: '/basari/' },
      { label: 'שולחן שוק חלבי', href: '/halavi/' },
      { label: 'שולחן שוק המבורגר', href: '/hamburger/' },
      { label: 'שולחן שוק שניצל', href: '/schnitzel/' },
      { label: 'שולחן שוק קינוחים', href: '/kinuchim/' },
      { label: 'שולחן שוק מטוגנים', href: '/metugganim/' },
      { label: 'שולחן שוק כשר למהדרין', href: '/kasher/' },
      { label: 'שולחן שוק צמחוני', href: '/tzimhoni/' },
    ],
  },
  {
    label: 'אירועים',
    href: '#',
    children: [
      { label: 'יום הולדת', href: '/yom-huledet/' },
      { label: 'בר/בת מצווה', href: '/bar-mitzva/' },
      { label: 'מסיבת רווקות', href: '/mesibat-ravakot/' },
      { label: 'חתונה', href: '/hatuna/' },
      { label: 'חינה', href: '/hina/' },
      { label: 'אירועי חברה', href: '/eruey-hevra/' },
      { label: 'שבת', href: '/shabat/' },
    ],
  },
  { label: 'תפריט', href: '/tafrit/' },
  { label: 'מחירים', href: '/mehirim/' },
  { label: 'גלריה', href: '/galeria/' },
  { label: 'אודות', href: '/odot/' },
  { label: 'בלוג', href: '/blog/' },
];

const currentPath = Astro.url.pathname;
const phone = '055-432-7900';
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-border shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20 md:h-24">
      <!-- Logo -->
      <a href="/" class="flex items-center group shrink-0 me-6">
        <img src="/images/logo.svg" alt="שולחן שוק" class="h-14 md:h-20 w-auto" />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-6">
        {navItems.map((item) => (
          <div class="relative group">
            {item.children ? (
              <>
                <button
                  class="text-sm font-medium text-dark hover:text-brand-600 transition-colors flex items-center gap-1 py-2"
                >
                  {item.label}
                  <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-200 absolute top-full end-0 mt-1 w-56 bg-white rounded-xl shadow-xl border border-border/50 py-2 z-50">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class:list={[
                        'block px-4 py-2.5 text-sm hover:bg-brand-50 hover:text-brand-700 transition-colors',
                        currentPath === child.href ? 'text-brand-600 bg-brand-50/50 font-medium' : 'text-dark',
                      ]}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </>
            ) : (
              <a
                href={item.href}
                class:list={[
                  'text-sm font-medium transition-colors hover:text-brand-600 py-2',
                  currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                    ? 'text-brand-600'
                    : 'text-dark',
                ]}
              >
                {item.label}
              </a>
            )}
          </div>
        ))}

        {phone && (
          <a
            href={`tel:${phone}`}
            class="bg-brand-600 text-white px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-brand-700 transition-all shadow-md hover:shadow-lg flex items-center gap-2"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {phone}
          </a>
        )}
      </div>

      <!-- Mobile: Phone + Menu Button -->
      <div class="flex items-center gap-3 lg:hidden">
        {phone && (
          <a
            href={`tel:${phone}`}
            class="bg-brand-600 text-white p-2.5 rounded-lg"
            aria-label="התקשרו אלינו"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </a>
        )}
        <button
          id="mobile-menu-btn"
          class="p-2 text-dark hover:text-brand-600 transition-colors"
          aria-label="פתח תפריט"
        >
          <svg id="menu-open-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4 border-t border-border/50 mt-2 pt-4">
      {navItems.map((item) => (
        <>
          {item.children ? (
            <details class="group">
              <summary class="flex items-center justify-between py-3 text-base font-medium text-dark cursor-pointer hover:text-brand-600 transition-colors">
                {item.label}
                <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="ps-4 pb-2 space-y-1">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class:list={[
                      'block py-2 text-sm transition-colors hover:text-brand-600',
                      currentPath === child.href ? 'text-brand-600 font-medium' : 'text-muted',
                    ]}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </details>
          ) : (
            <a
              href={item.href}
              class:list={[
                'block py-3 text-base font-medium transition-colors hover:text-brand-600',
                currentPath === item.href ? 'text-brand-600' : 'text-dark',
              ]}
            >
              {item.label}
            </a>
          )}
        </>
      ))}
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');

  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden', !isHidden ? false : true);
    closeIcon?.classList.toggle('hidden', !isHidden ? true : false);
    if (isHidden) {
      openIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
    } else {
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    }
  });
</script>
