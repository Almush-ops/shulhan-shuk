---
interface Logo {
  src: string;
  alt: string;
}

interface Props {
  title?: string;
  logos?: Logo[];
}

const { title = 'מהלקוחות שלנו', logos = [
  { src: '/images/logos/shufersal.png', alt: 'שופרסל' },
  { src: '/images/logos/matrix.png', alt: 'מטריקס' },
  { src: '/images/logos/egged.png', alt: 'אגד' },
  { src: '/images/logos/pmo.png', alt: 'משרד ראש הממשלה' },
  { src: '/images/logos/amal.png', alt: 'רשת עמל' },
  { src: '/images/logos/ort.jpg', alt: 'רשת אורט' },
  { src: '/images/logos/barkai.png', alt: 'מרכז ברקאי' },
  { src: '/images/logos/primor.png', alt: 'פרימור' },
  { src: '/images/logos/elem.png', alt: 'אלם מוצרי חשמל' },
  { src: '/images/logos/automazia.jpg', alt: 'אוטומציה החדשה' },
  { src: '/images/logos/dalton.jpg', alt: 'דלתון' },
] } = Astro.props;
---

<section class="py-10 md:py-12 bg-white border-b border-border/30">
  <div class="max-w-7xl mx-auto px-4">
    <p class="text-center text-sm text-muted mb-6">{title}</p>
    <div class="flex items-center justify-center gap-6 md:gap-10 overflow-x-auto">
      {logos.map((logo) => (
        <img
          src={logo.src}
          alt={logo.alt}
          class="h-8 md:h-10 w-auto object-contain"
          width="120"
          height="40"
          loading="lazy"
        />
      ))}
    </div>
  </div>
</section>
