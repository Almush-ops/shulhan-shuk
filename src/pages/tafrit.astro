---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCardForm from '../components/HeroCardForm.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTASection from '../components/CTASection.astro';
import FAQ from '../components/FAQ.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

const menuCategories = [
  {
    title: 'ירקות וסלטים',
    icon: '🥗',
    color: 'fresh',
    items: [
      'חומוס',
      'טחינה',
      'כרוב סגול',
      'מטבוחה',
      'פלטת ירקות — מלפפון, עגבניות שרי, פלפלים בצבעים',
      'סלט ירקות ישראלי קצוץ',
      'סלט כרוב לבן וגרעינים קלויים',
      'סלט עלי בייבי',
    ],
  },
  {
    title: 'מטוגנים',
    icon: '🍟',
    color: 'brand',
    items: [
      'צ\'יפס',
      'צ\'יפס בטטה',
      'טבעות בצל',
      'סיגרים בשר',
      'פסטלים תפוח אדמה',
      'נקניקיות נשנוש',
      'כדורי פירה',
      'פלאפל',
      'קובה',
    ],
  },
  {
    title: 'עיקריות',
    icon: '🍔',
    color: 'brand',
    items: [
      'לחמניות עם שניצל',
      'לחמניות עם המבורגר',
    ],
  },
  {
    title: 'פירות וקינוחי בוטיק',
    icon: '🍰',
    color: 'fresh',
    items: [
      'פירות העונה — אבטיח, מלון, אננס, ענבים, תותים, קיווי, פסיפלורה, תפוזים, פירות יער',
      'אקלרים',
      'פבלובות',
      'פחזניות',
      'קינוחי כוסות',
      'קרמבו פירות יער',
      'קרמבו בננה',
      'קינוחי מוס',
    ],
  },
];

const extras = [
  { name: 'פילה סלומון שלם אפוי', desc: 'פילה סלומון שלם ומרשים, אפוי בתנור עם עשבי תיבול' },
  { name: 'עראייס', desc: 'פיתות ממולאות בבשר טחון מתובל, צלויות על האש' },
  { name: 'קבב', desc: 'שיפודי קבב מתובלים, צלויים על האש' },
  { name: 'פרגיות', desc: 'פרגיות עסיסיות בתיבול מיוחד' },
  { name: 'אסאדו מפורק', desc: 'אסאדו מפורק רך ונמס בפה' },
  { name: 'גלגלי שווארמה', desc: 'שווארמה עסיסית על גלגל, חתוכה טרייה' },
  { name: 'אורז', desc: 'אורז לבן או אורז עם תוספות' },
  { name: 'פסטה', desc: 'פסטה ברוטב לבחירה' },
];

const faqItems = [
  { question: 'מה כלול בתפריט הסטנדרטי?', answer: 'התפריט הסטנדרטי כולל את כל מה שרואים ברשימה למעלה: ירקות וסלטים (8 מנות), מטוגנים (9 סוגים), עיקריות (שניצל + המבורגר בלחמניות), ופירות וקינוחי בוטיק. הכול מוכן טרי ביום האירוע. המחיר: 80-95 ₪ לאורח.' },
  { question: 'מה המחיר של התוספות?', answer: 'התוספות (סלומון, עראייס, קבב, פרגיות, אסאדו, שווארמה, אורז, פסטה) מתומחרות בנפרד לפי סוג המנה וכמות האורחים. צרו קשר ונתאים לכם הצעת מחיר מפורטת.' },
  { question: 'האם אפשר לשנות את התפריט?', answer: 'בהחלט! התפריט ניתן להתאמה אישית מלאה. אפשר להוסיף מנות, להחליף מנות, להתאים לאלרגיות או להעדפות תזונתיות, ולשלב כמה סוגי שולחנות באותו אירוע.' },
  { question: 'האם יש תפריט צמחוני / טבעוני?', answer: 'כן! אנחנו מציעים גם שולחן שוק צמחוני שכולל את כל הסלטים, חומוס, טחינה, פלאפל, ירקות, פירות וקינוחים — ללא בשר. אפשר להתאים גם לטבעונים.' },
  { question: 'האם יש תפריט חלבי?', answer: 'כן! בנוסף לתפריט הבשרי, אנחנו מציעים שולחן שוק חלבי עם גבינות מובחרות, מאפים טריים, סלטים, פירות וקינוחים. מושלם לברנצ\'ים, בריתות וארוחות בוקר.' },
  { question: 'כמה אורחים צריך מינימום?', answer: 'המינימום הוא 20 אורחים. ככל שיש יותר אורחים, המחיר לאורח יורד: 20 סועדים — 95 ₪, 30 — 90 ₪, 40 — 85 ₪, 50 — 80 ₪.' },
];

const menuSchema = {
  '@context': 'https://schema.org',
  '@type': 'Menu',
  name: 'תפריט שולחן שוק',
  description: 'התפריט המלא של שולחן שוק — ירקות וסלטים, מטוגנים, עיקריות, פירות וקינוחי בוטיק. כשר למהדרין.',
  url: 'https://shulhan-shuk.co.il/tafrit/',
  hasMenuSection: menuCategories.map(cat => ({
    '@type': 'MenuSection',
    name: cat.title,
    hasMenuItem: cat.items.map(item => ({
      '@type': 'MenuItem',
      name: item,
    })),
  })),
};
---

<BaseLayout
  title="תפריט שולחן שוק — כל המנות והתוספות"
  description="התפריט המלא של שולחן שוק: ירקות וסלטים, 9 סוגי מטוגנים, שניצל, המבורגר, פירות וקינוחי בוטיק. כשר למהדרין. תוספות: סלומון, קבב, שווארמה ועוד."
>
  <HeroCardForm
    title="התפריט שלנו"
    subtitle="כל המנות מוכנות טרי ביום האירוע מחומרי גלם איכותיים — כשר למהדרין"
    backgroundImage="/images/hero/hero-02.webp"
  />

  <section class="py-8">
    <div class="max-w-4xl mx-auto px-4">
      <Breadcrumbs items={[{ label: 'תפריט' }]} />
    </div>
  </section>

  <!-- תפריט סטנדרטי -->
  <section class="py-12 md:py-16">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-3xl font-heading text-dark mb-3">התפריט הסטנדרטי</h2>
        <p class="text-muted max-w-2xl mx-auto">כל המנות הבאות כלולות במחיר — 80 עד 95 ₪ לאורח, לפי כמות הסועדים</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {menuCategories.map((cat) => (
          <div class="relative bg-white rounded-2xl shadow-sm border border-border/50 overflow-hidden">
            <div class={`h-1.5 ${cat.color === 'fresh' ? 'bg-fresh-500' : 'bg-brand-500'}`}></div>
            <div class="p-6 md:p-8">
              <div class="flex items-center gap-3 mb-5">
                <span class="text-3xl">{cat.icon}</span>
                <h3 class="text-xl font-heading text-dark">{cat.title}</h3>
              </div>
              <ul class="space-y-3">
                {cat.items.map((item) => (
                  <li class="flex items-start gap-3 text-muted">
                    <svg class={`w-4 h-4 mt-0.5 flex-shrink-0 ${cat.color === 'fresh' ? 'text-fresh-500' : 'text-brand-500'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- אופציה לתוספות -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-heading text-dark mb-3">אפשר להוסיף</h2>
        <p class="text-muted max-w-2xl mx-auto">מנות נוספות שאפשר להוסיף לשולחן — בתשלום נפרד, לפי סוג המנה וכמות האורחים</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {extras.map((extra) => (
          <div class="bg-white p-5 rounded-2xl shadow-sm border border-border/50 hover:shadow-md transition-shadow">
            <h4 class="font-bold text-dark mb-1">{extra.name}</h4>
            <p class="text-sm text-muted">{extra.desc}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 p-6 bg-white rounded-2xl border border-brand-200 text-center">
        <p class="text-dark font-medium mb-2">רוצים לדעת כמה עולה התוספת?</p>
        <p class="text-sm text-muted mb-4">צרו קשר ושרית תבנה לכם הצעת מחיר מפורטת — כולל התפריט הסטנדרטי + כל התוספות שתרצו</p>
        <a href="tel:055-432-7900" class="inline-flex items-center gap-2 px-5 py-2.5 bg-brand-600 text-white rounded-full font-medium hover:bg-brand-700 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          055-432-7900
        </a>
      </div>
    </div>
  </section>

  <!-- מידע נוסף על התפריט -->
  <section class="py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4">
      <div class="prose max-w-none">
        <h2>על התפריט של שולחן שוק</h2>
        <p>התפריט של שולחן שוק תוכנן כך שכל אורח ימצא בו משהו שהוא אוהב. השולחן כולל מגוון רחב של טעמים, מרקמים וסגנונות — מסלטים טריים וקלילים, דרך מטוגנים חמים ופריכים, ועד קינוחי בוטיק מפנקים.</p>

        <h3>הכנה טרייה ביום האירוע</h3>
        <p>כל המנות מוכנות טרי ביום האירוע — לא משתמשים בחומרי גלם מוכנים מראש או קפואים. הסלטים נקצצים, המטוגנים מוכנים, השניצלים וההמבורגרים נצלים, והקינוחים מוכנים — הכול ביום האירוע עצמו, כדי שהאורחים ייהנו מטריות מקסימלית.</p>

        <h3>כשר למהדרין</h3>
        <p>כל המנות בתפריט כשרות למהדרין. אנחנו עובדים עם חומרי גלם מהודרים בלבד, תחת השגחת כשרות צמודה, עם הפרדה מלאה בין בשרי לחלבי. <a href="/kasher/">לפרטים על הכשרות שלנו</a>.</p>

        <h3>התאמה אישית</h3>
        <p>התפריט הסטנדרטי הוא נקודת מוצא — אפשר להתאים אותו לפי סוג האירוע, העדפות האורחים, אלרגיות מזון ודרישות מיוחדות. אם יש מנה שתרצו להוסיף או להחליף — נשמח להתאים. יש לנו גם <a href="/halavi/">תפריט חלבי</a>, <a href="/tzimhoni/">תפריט צמחוני</a> ואפשרות לשלב כמה סוגי שולחנות באותו אירוע.</p>

        <h3>מחירים</h3>
        <p>התפריט הסטנדרטי עולה בין 80 ל-95 ₪ לאורח, תלוי בכמות הסועדים. המחיר כולל את כל מה שברשימה למעלה, בתוספת הגעה, סידור, הגשה ופינוי. תוספות מתומחרות בנפרד. <a href="/mehirim/">למחירון המלא</a>.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-surface">
    <FAQ items={faqItems} title="שאלות נפוצות על התפריט" />
  </section>

  <CTASection
    title="רוצים לבנות תפריט לאירוע?"
    subtitle="ספרו לנו על האירוע ונבנה תפריט מותאם אישית — תוך שעה"
    phone="055-432-7900"
  />

  <SchemaOrg schema={menuSchema} />
</BaseLayout>
