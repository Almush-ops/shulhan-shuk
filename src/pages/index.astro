---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCardForm from '../components/HeroCardForm.astro';
import TrustBar from '../components/TrustBar.astro';
import ServiceCard from '../components/ServiceCard.astro';
import PricingTable from '../components/PricingTable.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
import AreasGrid from '../components/AreasGrid.astro';
import FAQ from '../components/FAQ.astro';
import CTASection from '../components/CTASection.astro';
import TrustBarLogos from '../components/TrustBarLogos.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import ProcessSteps from '../components/ProcessSteps.astro';

const serviceTypes = [
  { title: 'שולחן שוק בשרי', description: 'שולחן שוק בשרי עם שניצל, המבורגר, 9 סוגי מטוגנים, סלטים טריים וקינוחי בוטיק. אפשר להוסיף פרגיות, קבב, אסאדו מפורק, גלגלי שווארמה ועוד.', href: '/basari/', image: '/images/gallery/img-01.webp' },
  { title: 'שולחן שוק חלבי', description: 'שולחן שוק חלבי עם גבינות מובחרות, מאפים טריים מהתנור, סלטים צבעוניים, פירות עונתיים, מריחות ודיפים. מושלם לברנצ\'ים ואירועים אלגנטיים.', href: '/halavi/', image: '/images/gallery/img-10.webp' },
  { title: 'שולחן שוק המבורגר', description: 'לחמניות עם המבורגר טרי לצד צ\'יפס, צ\'יפס בטטה, טבעות בצל, סלטים, חומוס וטחינה. חגיגת המבורגר בסגנון שוק.', href: '/hamburger/', image: '/images/gallery/img-04.webp' },
  { title: 'שולחן שוק שניצל', description: 'לחמניות עם שניצל פריך, צ\'יפס, כדורי פירה, סלטים טריים, חומוס וטחינה. המנה שכולם אוהבים — בסגנון שוק מפנק.', href: '/schnitzel/', image: '/images/gallery/img-15.webp' },
  { title: 'שולחן שוק קינוחים', description: 'אקלרים, פבלובות, פחזניות, קינוחי כוסות, קרמבו פירות יער, קרמבו בננה, קינוחי מוס ומגש פירות העונה — חגיגה מתוקה.', href: '/kinuchim/', image: '/images/gallery/img-20.webp' },
  { title: 'שולחן שוק מטוגנים', description: 'צ\'יפס, צ\'יפס בטטה, טבעות בצל, סיגרים בשר, פסטלים, נקניקיות נשנוש, כדורי פירה, פלאפל וקובה — 9 סוגי מטוגנים חמים.', href: '/metugganim/', image: '/images/gallery/img-06.webp' },
  { title: 'שולחן שוק כשר למהדרין', description: 'כל השולחנות שלנו כשרים למהדרין בהשגחה צמודה. תעודת כשרות מהדרין, חומרי גלם מהודרים והפרדה מלאה בין בשרי לחלבי.', href: '/kasher/', image: '/images/gallery/img-30.webp' },
  { title: 'שולחן שוק צמחוני', description: 'חומוס, טחינה, פלאפל, סלטים טריים, ירקות, מטבוחה, כרוב סגול, פירות העונה וקינוחי בוטיק — שולחן שוק עשיר ללא בשר.', href: '/tzimhoni/', image: '/images/gallery/img-40.webp' },
];

const eventTypes = [
  { title: 'יום הולדת', description: 'שולחן שוק ליום הולדת — חגיגה קולינרית שכולם יזכרו.', href: '/yom-huledet/', image: '/images/gallery/img-25.webp' },
  { title: 'בר/בת מצווה', description: 'שולחן שוק מרשים לבר ובת מצווה. מגוון שולחנות בשרי, חלבי או מעורב.', href: '/bar-mitzva/', image: '/images/gallery/img-32.webp' },
  { title: 'מסיבת רווקות', description: 'שולחן שוק למסיבת רווקות — עיצוב מפנק ותפריט מושלם למסיבה.', href: '/mesibat-ravakot/', image: '/images/gallery/img-35.webp' },
  { title: 'חתונה', description: 'קייטרינג שולחן שוק לחתונה — קבלת פנים מרשימה או ארוחה מלאה.', href: '/hatuna/', image: '/images/gallery/img-45.webp' },
  { title: 'חינה', description: 'שולחן שוק לחינה — חגיגה מסורתית עם אוכל עשיר ומגוון.', href: '/hina/', image: '/images/gallery/img-50.webp' },
  { title: 'אירועי חברה', description: 'קייטרינג שולחן שוק לאירועי חברה, כנסים, השקות ומפגשי עובדים.', href: '/eruey-hevra/', image: '/images/gallery/img-55.webp' },
  { title: 'שבת', description: 'שולחן שוק לשבת — ארוחה מוכנה ומפנקת לכל המשפחה.', href: '/shabat/', image: '/images/gallery/img-60.webp' },
];

const whyUsFeatures = [
  { icon: 'clock', title: 'מענה תוך שעה', desc: 'משאירים פרטים ומקבלים הצעת מחיר מפורטת תוך שעה — ללא התחייבות ובלי לחץ.' },
  { icon: 'truck', title: 'פריסה ארצית', desc: 'מגיעים לכל מקום בארץ — מקריית שמונה ועד אילת, כולל ערים, ישובים ואזורי תעשייה.' },
  { icon: 'certificate', title: 'כשר למהדרין', desc: 'תעודת כשרות מהדרין, השגחה צמודה, חומרי גלם מהודרים והפרדה מלאה בין בשרי לחלבי.' },
  { icon: 'wallet', title: 'מחירים שקופים', desc: '80-95 ₪ לאורח, תלוי בכמות — כולל הכנה, הגעה, סידור, הגשה ופינוי. בלי הפתעות.' },
  { icon: 'star', title: 'הכנה טרייה ביום האירוע', desc: 'לא משתמשים בחומרי גלם מוכנים מראש. הכול מוכן טרי ביום האירוע מחומרי גלם איכותיים.' },
  { icon: 'users', title: 'שירות מקצה לקצה', desc: 'ייעוץ אישי, בניית תפריט, הכנה, הגעה, סידור ועיצוב, הגשה ופינוי — אתם רק נהנים.' },
];

const testimonials = [
  { name: 'מיכל כ.', text: 'הזמנו שולחן שוק בשרי ליום הולדת 40. שרית התאימה לנו תפריט מדויק, הכול הגיע טרי וחם, והסידור של השולחן היה פשוט מרשים. האורחים שלנו לא הפסיקו לאכול ולצלם.', event: 'יום הולדת, 50 אורחים', rating: 5 },
  { name: 'אורי ד.', text: 'לקחנו שולחן שוק המבורגר לבר מצווה. הילדים אהבו, המבוגרים אהבו, כולם אכלו. השירות היה מקצועי, הגיעו בזמן וסידרו הכול. הייתי שמח אם המטוגנים היו קצת פחות שמנוניים, אבל בסך הכל ממליץ.', event: 'בר מצווה, 80 אורחים', rating: 4 },
  { name: 'רונית ש.', text: 'שולחן שוק חלבי למסיבת רווקות — זה היה הלהיט של הערב. הגבינות והמאפים טריים, העיצוב מושלם, ושרית היתה זמינה לכל שאלה גם בערב עצמו. ממליצה בלי לחשוב פעמיים.', event: 'מסיבת רווקות, 25 אורחות', rating: 5 },
  { name: 'דוד מ.', text: 'מזמינים כבר פעם שלישית לאירועי חברה. השירות עקבי, האוכל תמיד טרי, והמחיר הוגן. בפעם האחרונה ביקשנו גם תוספת אסאדו וזה היה שווה כל שקל. תמיד מקבלים מחמאות מהעובדים.', event: 'אירוע חברה, 100 איש', rating: 5 },
  { name: 'יעל ג.', text: 'הזמנתי שולחן שוק כשר למהדרין לשבת חתן. היה חשוב לנו שהכשרות תהיה ברמה הכי גבוהה, ושרית דאגה לכל פרט. האוכל היה מצוין, ההגשה מכובדת, והפינוי מהיר. השולחן קצת קטן ל-40 איש, אבל הסתדרנו.', event: 'שבת חתן, 40 אורחים', rating: 4 },
  { name: 'עמית ל.', text: 'שולחן שוק לחינה של האחות. רצינו משהו מיוחד וקיבלנו בדיוק את זה — שולחן ענק, צבעוני, עם המון אוכל. כל המשפחה התלהבה. שרית מקצוענית אמיתית.', event: 'חינה, 70 אורחים', rating: 5 },
];

const faqItems = [
  { question: 'מה זה שולחן שוק?', answer: 'שולחן שוק הוא קונספט קייטרינג שבו האוכל מוגש על שולחן ארוך ומעוצב בסגנון שוק אוכל — עשיר, צבעוני ושופע. השולחן כולל ירקות וסלטים (חומוס, טחינה, סלטים טריים), מנות עיקריות (שניצל, המבורגר), מגוון מטוגנים (צ\'יפס, פלאפל, קובה ועוד), ופירות וקינוחי בוטיק. זו חוויה ויזואלית וקולינרית שמתאימה לכל סוג אירוע — מיום הולדת ועד חתונה.' },
  { question: 'כמה עולה שולחן שוק?', answer: 'המחיר נע בין 80 ל-95 ₪ לאורח, לפי כמות הסועדים: 20 סועדים — 95 ₪, 30 סועדים — 90 ₪, 40 סועדים — 85 ₪ (הכי פופולרי), 50 סועדים — 80 ₪. המחיר כולל הכנה טרייה, הגעה למקום, סידור ועיצוב השולחן, הגשה ופינוי. <a href="/mehirim/" class="text-brand-600 hover:underline">למחירון המלא לחצו כאן</a>.' },
  { question: 'מה כלול בשולחן שוק?', answer: 'החבילה הסטנדרטית כוללת: ירקות וסלטים (חומוס, טחינה, כרוב סגול, מטבוחה, פלטת ירקות, סלט ישראלי, סלט כרוב, סלט עלי בייבי), מטוגנים (צ\'יפס, צ\'יפס בטטה, טבעות בצל, סיגרים בשר, פסטלים, נקניקיות, כדורי פירה, פלאפל, קובה), עיקריות (לחמניות שניצל + לחמניות המבורגר), ופירות וקינוחי בוטיק (אקלרים, פבלובות, פחזניות, קרמבו ועוד). אפשר להוסיף תוספות כמו פילה סלומון, עראייס, קבב, פרגיות, אסאדו ושווארמה.' },
  { question: 'לאילו אירועים מתאים שולחן שוק?', answer: 'שולחן שוק מתאים לכל סוג אירוע: <a href="/yom-huledet/" class="text-brand-600 hover:underline">ימי הולדת</a>, <a href="/bar-mitzva/" class="text-brand-600 hover:underline">בר/בת מצווה</a>, <a href="/hatuna/" class="text-brand-600 hover:underline">חתונות</a>, <a href="/mesibat-ravakot/" class="text-brand-600 hover:underline">מסיבות רווקות</a>, <a href="/hina/" class="text-brand-600 hover:underline">חינות</a>, <a href="/eruey-hevra/" class="text-brand-600 hover:underline">אירועי חברה</a> ו<a href="/shabat/" class="text-brand-600 hover:underline">ארוחות שבת</a>. אנחנו מתאימים את סוג השולחן, התפריט והעיצוב לאירוע שלכם.' },
  { question: 'מה המינימום להזמנה?', answer: 'המינימום הוא 20 אורחים. לאירועים קטנים יותר ניתן ליצור קשר ולבדוק אפשרויות מותאמות.' },
  { question: 'האם אתם מגיעים לכל הארץ?', answer: 'כן! אנחנו מגיעים לכל מקום בישראל — <a href="/tel-aviv/" class="text-brand-600 hover:underline">תל אביב</a>, <a href="/haifa/" class="text-brand-600 hover:underline">חיפה</a>, <a href="/yerushalayim/" class="text-brand-600 hover:underline">ירושלים</a>, <a href="/beer-sheva/" class="text-brand-600 hover:underline">באר שבע</a> ולכל ישוב בארץ. ההגעה, הסידור וההגשה כלולים במחיר.' },
  { question: 'האם השולחנות כשרים?', answer: 'כל השולחנות שלנו כשרים למהדרין. אנחנו עובדים עם תעודת כשרות מהדרין, השגחה צמודה, חומרי גלם מהודרים בלבד והפרדה מלאה בין בשרי לחלבי. <a href="/kasher/" class="text-brand-600 hover:underline">לפרטים נוספים על הכשרות</a>.' },
  { question: 'כמה זמן לפני האירוע צריך להזמין?', answer: 'מומלץ להזמין לפחות שבוע מראש, במיוחד בעונות חגים ואירועים (פורים, פסח, קיץ). בזמינות — אפשר גם בהתראה קצרה יותר. השאירו פרטים ונחזור אליכם תוך שעה.' },
  { question: 'מה ההבדל בין סוגי השולחנות?', answer: 'החבילה הבסיסית כוללת שניצל, המבורגר, מטוגנים, סלטים, פירות וקינוחי בוטיק. ההבדל בין הסוגים הוא בדגש: <a href="/basari/" class="text-brand-600 hover:underline">שולחן בשרי</a> מדגיש בשרים עם תוספות כמו שווארמה וקבב, <a href="/halavi/" class="text-brand-600 hover:underline">שולחן חלבי</a> מציע גבינות ומאפים, <a href="/hamburger/" class="text-brand-600 hover:underline">שולחן המבורגר</a> מתמקד בהמבורגרים, וכן הלאה. אפשר גם לשלב כמה סוגים.' },
  { question: 'האם אפשר להתאים את התפריט?', answer: 'בהחלט! אנחנו מתאימים את התפריט לפי הצרכים שלכם — אלרגיות, העדפות אישיות, תקציב, סוג האירוע וכמות האורחים. אפשר להוסיף או להחליף מנות, לשלב סוגי שולחנות ולהתאים את העיצוב.' },
  { question: 'איך מזמינים שולחן שוק?', answer: 'משאירים פרטים בטופס באתר או מתקשרים ל-055-432-7900. שרית חוזרת אליכם תוך שעה עם הצעת מחיר מפורטת — ללא התחייבות.' },
];

const galleryImages = [
  { src: '/images/gallery/img-01.webp', alt: 'שולחן שוק מרשים עם סלטים, לחמניות ופלאפל' },
  { src: '/images/gallery/img-04.webp', alt: 'שולחן שוק ארוך עם מגוון מנות ומטוגנים' },
  { src: '/images/gallery/img-06.webp', alt: 'שולחן שוק חגיגי עם דגלי ישראל' },
  { src: '/images/gallery/img-10.webp', alt: 'שולחן שוק עם ירקות טריים ופיתות' },
  { src: '/images/gallery/img-15.webp', alt: 'עיצוב שולחן שוק לאירוע' },
  { src: '/images/gallery/img-20.webp', alt: 'מגש ירקות טריים צבעוני' },
  { src: '/images/gallery/img-30.webp', alt: 'שולחן שוק מוכן לאירוע' },
  { src: '/images/gallery/img-40.webp', alt: 'שולחן שוק עם מגוון מנות' },
];

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'FoodService',
  name: 'שולחן שוק',
  description: 'שולחן שוק לכל אירוע — בשרי, חלבי, המבורגר, שניצל, קינוחים ועוד. כשר למהדרין. פריסה ארצית.',
  url: 'https://shulhan-shuk.co.il',
  telephone: '+972-55-432-7900',
  areaServed: { '@type': 'Country', name: 'Israel' },
  priceRange: '₪₪',
  image: 'https://shulhan-shuk.co.il/images/social.jpg',
  // aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: 'XX' }, // TBD
};
---

<BaseLayout
  title="שולחן שוק לכל אירוע — בשרי, חלבי, המבורגר ועוד | שולחן שוק"
  description="שולחן שוק לכל אירוע — בשרי, חלבי, המבורגר, שניצל ועוד. כשר למהדרין, פריסה ארצית, מחירים שקופים. קבלו הצעת מחיר תוך שעה!"
  preloadImage="/images/hero/hero-01.webp"
>
  <!-- 1. Hero + Lead Form -->
  <HeroCardForm
    title="שולחן שוק לכל אירוע"
    subtitle="בשרי, חלבי, המבורגר, שניצל ועוד — משלוח והגשה בכל הארץ. כשר למהדרין."
    backgroundImage="/images/hero/hero-01.webp"
    trustItems={['פריסה ארצית', 'כשר למהדרין', 'מחירים שקופים', 'מענה תוך שעה']}
  />

  <!-- 2. Trust Numbers -->
  <TrustBar />

  <!-- 3. מה זה שולחן שוק (Split Image + Text) -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div class="order-2 lg:order-1">
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-6">מה זה שולחן שוק?</h2>
          <p class="text-muted leading-relaxed mb-4">
            שולחן שוק הוא קונספט קייטרינג ישראלי שבו האוכל מוגש על שולחן ארוך ומעוצב בסגנון שוק אוכל — עשיר, צבעוני ושופע. במקום מנות מוגשות בצלחות, האורחים ניגשים לשולחן, בוחרים ממגוון המנות, טועמים ומגלים טעמים חדשים. זו חוויה קולינרית שמתאימה לכל סוג אירוע ולכל גיל.
          </p>
          <p class="text-muted leading-relaxed mb-4">
