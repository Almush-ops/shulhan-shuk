---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCardForm from '../components/HeroCardForm.astro';
import FAQ from '../components/FAQ.astro';
import CTASection from '../components/CTASection.astro';
import ServiceCard from '../components/ServiceCard.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

export async function getStaticPaths() {
  const services = await getCollection('services');
  const events = await getCollection('events');
  const areas = await getCollection('areas');

  const servicePaths = services.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, type: 'service' as const },
  }));

  const eventPaths = events.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, type: 'event' as const },
  }));

  const areaPaths = areas.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, type: 'area' as const },
  }));

  return [...servicePaths, ...eventPaths, ...areaPaths];
}

const { entry, type } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;

const typeLabels = { service: 'שירותים', event: 'אירועים', area: 'אזורי שירות' };
const breadcrumbItems = [
  { label: typeLabels[type] },
  { label: data.title },
];

// Schema per type
const pageSchema = type === 'service' ? {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: data.title,
  description: data.description,
  image: (data as any).image ? `https://shulhan-shuk.co.il${(data as any).image}` : undefined,
  ...(data.priceRange ? {
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'ILS',
      lowPrice: 80,
      highPrice: 95,
      offerCount: 4,
      availability: 'https://schema.org/InStock',
    },
  } : {}),
} : type === 'area' ? {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: `שולחן שוק ${(data as any).city || ''}`.trim(),
  description: data.description,
  telephone: '055-432-7900',
  url: `https://shulhan-shuk.co.il/${entry.slug}/`,
  priceRange: '₪₪',
  image: 'https://shulhan-shuk.co.il/images/social.jpg',
  areaServed: { '@type': 'City', name: (data as any).city },
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'IL',
    addressRegion: (data as any).city,
  },
} : {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: data.title,
  description: data.description,
  image: (data as any).image ? `https://shulhan-shuk.co.il${(data as any).image}` : undefined,
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'ILS',
    lowPrice: 80,
    highPrice: 95,
    offerCount: 4,
    availability: 'https://schema.org/InStock',
  },
};
---

<BaseLayout
  title={data.title}
  description={data.description}
  ogType={type === 'area' ? 'website' : 'product'}
>
  <!-- Hero with form -->
  <HeroCardForm
    title={data.heroTitle}
    subtitle={(data as any).heroSubtitle}
    backgroundImage={(data as any).image}
  />

  <!-- Content area -->
  <section class="py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Breadcrumbs -->
      <Breadcrumbs items={breadcrumbItems} />

      <!-- Main content from markdown -->
      <div class="prose max-w-none">
        <Content />
      </div>

      <!-- Price info for services -->
      {type === 'service' && (data as any).priceRange && (
        <div class="mt-8 p-6 md:p-8 bg-brand-50 rounded-2xl border border-brand-200 text-center">
          <h3 class="text-sm font-semibold text-muted uppercase tracking-wide mb-2">מחיר</h3>
          <p class="text-4xl font-bold text-brand-700 mb-1">{(data as any).priceRange}</p>
          {(data as any).minGuests && <p class="text-sm text-muted">מינימום: {(data as any).minGuests}</p>}
          {(data as any).includes && (
            <div class="mt-5 pt-5 border-t border-brand-200/60 text-start">
              <p class="text-sm font-semibold text-dark mb-3">כולל:</p>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-2.5">
                {(data as any).includes.map((item: string) => (
                  <li class="flex items-center gap-2.5 text-sm text-muted">
                    <svg class="w-4 h-4 text-fresh-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      )}

      <!-- Recommended tables for events -->
      {type === 'event' && (data as any).recommendedTables && (
        <div class="mt-10">
          <h3 class="text-xl font-bold text-dark mb-6">שולחנות שוק מומלצים</h3>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            {(data as any).recommendedTables.map((table: any) => (
              <ServiceCard title={table.title} description="" href={table.href} />
            ))}
          </div>
        </div>
      )}

      <!-- Nearby areas for area pages -->
      {type === 'area' && (data as any).nearbyAreas && (
        <div class="mt-10">
          <h3 class="text-xl font-bold text-dark mb-4">אזורי שירות נוספים</h3>
          <div class="flex flex-wrap gap-2">
            {(data as any).nearbyAreas.map((area: string) => (
              <span class="px-3 py-1.5 bg-surface rounded-full text-sm text-muted border border-border">{area}</span>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- FAQ -->
  {data.faq && data.faq.length > 0 && (
    <section class="bg-surface">
      <FAQ items={data.faq} />
    </section>
  )}

  <!-- Bottom CTA -->
  <CTASection phone="055-432-7900" />

  <!-- Schema -->
  <SchemaOrg schema={pageSchema} />
</BaseLayout>
