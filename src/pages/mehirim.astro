---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCardForm from '../components/HeroCardForm.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PricingTable from '../components/PricingTable.astro';
import FAQ from '../components/FAQ.astro';
import CTASection from '../components/CTASection.astro';

const pricingFaq = [
  { question: 'כמה עולה שולחן שוק?', answer: 'שולחן שוק עולה 80-95 ₪ לאורח, לפי כמות הסועדים: 20 סועדים — 95 ₪, 30 סועדים — 90 ₪, 40 סועדים — 85 ₪, 50 סועדים — 80 ₪. המחיר אחיד לכל סוגי השולחנות (בשרי, חלבי, המבורגר, שניצל, צמחוני). כולל הכנה, הגעה, סידור, הגשה ופינוי.' },
  { question: 'מה כלול במחיר?', answer: 'המחיר כולל תפריט מלא: שניצל בלחמניות + המבורגר בלחמניות + 9 סוגי מטוגנים (צ\'יפס, צ\'יפס בטטה, טבעות בצל, סיגרים, פסטלים, נקניקיות, כדורי פירה, פלאפל, קובה) + 8 סלטים + פירות העונה + קינוחי בוטיק. בנוסף: הכנה טרייה ביום האירוע, הגעה, סידור, הגשה ופינוי. <a href="/tafrit/" class="text-brand-600 hover:underline">לתפריט המלא</a>.' },
  { question: 'האם יש עלויות נסתרות?', answer: 'לא. המחיר שמצוטט כולל הכול — חומרי גלם, הכנה, הגעה, סידור, הגשה, פינוי, כשרות למהדרין ותעודת כשרות. באזורים מרוחקים מהמרכז ייתכן חיוב נסיעה קטן (מתואם מראש). תוספות מיוחדות בתמחור נפרד.' },
  { question: 'מה המינימום להזמנה?', answer: 'המינימום הוא 20 אורחים בכל סוגי השולחנות. לאירועים קטנים יותר — צרו קשר ונמצא פתרון.' },
  { question: 'יש הנחה לאירועים גדולים?', answer: 'המחיר כבר יורד ככל שגדל מספר האורחים: 50 איש = 80 ₪ לאורח (במקום 95 ₪ ל-20 איש). לאירועים מעל 80 אורחים — צרו קשר להצעת מחיר מותאמת.' },
  { question: 'כמה עולות התוספות?', answer: 'תוספות כמו פרגיות, קבב, שווארמה, אסאדו, עראייס, אורז ופסטה — בתמחור נפרד. הסכום תלוי בכמות הסועדים ובסוג התוספת. צרו קשר וקבלו הצעה.' },
  { question: 'איך משלמים?', answer: 'תשלום במזומן, העברה בנקאית או כרטיס אשראי. מקדמה של 30% בעת ההזמנה, והיתר ביום האירוע. חשבונית מס לאירועים עסקיים.' },
  { question: 'מה מדיניות הביטול?', answer: 'ביטול עד 7 ימים לפני האירוע — החזר מלא של המקדמה. ביטול 3-7 ימים — החזר 50%. ביטול פחות מ-3 ימים — ללא החזר.' },
  { question: 'האם אפשר לשנות את כמות האורחים?', answer: 'כן! ניתן לעדכן את כמות האורחים עד 3 ימים לפני האירוע. המחיר יתעדכן בהתאם.' },
  { question: 'האם הכשרות למהדרין עולה יותר?', answer: 'לא. הכשרות למהדרין כלולה במחיר הסטנדרטי — ללא תוספת. כל השולחנות כשרים למהדרין מלכתחילה. <a href="/kasher/" class="text-brand-600 hover:underline">לפרטים על הכשרות</a>.' },
];
---

<BaseLayout
  title="מחירון שולחן שוק — כמה עולה שולחן שוק? מחירים שקופים"
  description="מחירון שולחן שוק מפורט: 80-95 ₪ לאורח, כולל שניצל, המבורגר, 9 מטוגנים, 8 סלטים, פירות וקינוחי בוטיק. הכנה, הגעה, סידור, הגשה ופינוי."
  ogType="product"
>
  <HeroCardForm
    title="כמה עולה שולחן שוק?"
    subtitle="80-95 ₪ לאורח — מחירים שקופים, בלי הפתעות, הכול כלול"
    formTitle="קבלו הצעת מחיר מדויקת"
  />

  <section class="py-8">
    <div class="max-w-4xl mx-auto px-4">
      <Breadcrumbs items={[{ label: 'מחירון' }]} />
    </div>
  </section>

  <PricingTable />

  <!-- What's included in the price -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-heading text-dark mb-4">מה כלול במחיר?</h2>
      <p class="text-muted mb-8">כל שולחן שוק כולל <a href="/tafrit/" class="text-brand-600 hover:underline">תפריט מלא</a> — ללא תוספות נסתרות:</p>

      <div class="grid md:grid-cols-2 gap-6 mb-10">
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-border/50">
          <h3 class="font-bold text-dark mb-3 text-lg">עיקריות</h3>
          <ul class="text-sm text-muted space-y-1.5">
            <li>שניצל פריך בלחמניות רכות</li>
            <li>המבורגר טרי בלחמניות</li>
          </ul>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-border/50">
          <h3 class="font-bold text-dark mb-3 text-lg">9 סוגי מטוגנים</h3>
          <ul class="text-sm text-muted space-y-1.5">
            <li>צ'יפס, צ'יפס בטטה, טבעות בצל</li>
            <li>סיגרים בשר, פסטלים, נקניקיות</li>
            <li>כדורי פירה, פלאפל, קובה</li>
          </ul>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-border/50">
          <h3 class="font-bold text-dark mb-3 text-lg">8 סלטים וירקות</h3>
          <ul class="text-sm text-muted space-y-1.5">
            <li>חומוס, טחינה, כרוב סגול, מטבוחה</li>
            <li>פלטת ירקות, סלט ישראלי, סלט כרוב, עלי בייבי</li>
          </ul>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-border/50">
          <h3 class="font-bold text-dark mb-3 text-lg">פירות וקינוחי בוטיק</h3>
          <ul class="text-sm text-muted space-y-1.5">
            <li>מגש פירות העונה מעוצב</li>
            <li>אקלרים, פבלובות, פחזניות, קרמבו, מוס</li>
          </ul>
        </div>
      </div>

      <div class="bg-brand-50 p-6 rounded-2xl border border-brand-200">
        <h3 class="font-bold text-dark mb-2">גם כלול במחיר:</h3>
        <div class="grid sm:grid-cols-3 gap-3 text-sm text-muted">
          <div>הכנה טרייה ביום האירוע</div>
          <div>הגעה לכל מקום בארץ</div>
          <div>סידור ועיצוב השולחן</div>
          <div>הגשה מקצועית</div>
          <div>פינוי וניקיון</div>
          <div><a href="/kasher/" class="text-brand-600 hover:underline">כשרות למהדרין + תעודה</a></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Extras -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-heading text-dark mb-4">תוספות — בתמחור נפרד</h2>
      <p class="text-muted mb-8">רוצים להרחיב את השולחן? אפשר להוסיף מנות מיוחדות:</p>

      <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        {[
          'סלמון', 'עראייס', 'קבב', 'פרגיות',
          'אסאדו מפורק', 'שווארמה מגלגל', 'אורז', 'פסטה'
        ].map((item) => (
          <div class="bg-white p-4 rounded-xl shadow-sm border border-border/50 text-center">
            <span class="text-sm font-medium text-dark">{item}</span>
          </div>
        ))}
      </div>

      <p class="text-sm text-muted">המחיר לכל תוספת תלוי בכמות הסועדים. <strong>צרו קשר</strong> ושרית תבנה הצעה מותאמת.</p>
    </div>
  </section>

  <!-- What affects the price -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-heading text-dark mb-6">מה משפיע על המחיר?</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          { title: 'כמות אורחים', desc: 'הגורם המשמעותי ביותר. 20 אורחים = 95 ₪, 50 אורחים = 80 ₪. ככל שיש יותר אורחים, המחיר לאורח יורד.' },
          { title: 'תוספות', desc: 'תוספות כמו שווארמה, קבב, פרגיות או אסאדו — בתמחור נפרד. החבילה הסטנדרטית כבר כוללת 30+ מנות.' },
          { title: 'מיקום', desc: 'באזור המרכז ללא תוספת. באזורים מרוחקים (צפון/דרום) ייתכן חיוב נסיעה קטן שמתואם מראש.' },
          { title: 'גודל האירוע', desc: 'לאירועים גדולים (80+ אורחים) יש הנחת כמות נוספת. צרו קשר להצעה מותאמת.' },
        ].map((item) => (
          <div class="bg-white p-5 rounded-2xl shadow-sm border border-border/50">
            <h3 class="font-bold text-dark mb-1">{item.title}</h3>
            <p class="text-sm text-muted">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing prose content for SEO -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <div class="prose max-w-none">
        <h2>כמה עולה שולחן שוק? — המדריך המלא למחירים</h2>

        <p>שולחן שוק עולה <strong>80-95 ₪ לאורח</strong>, כאשר המחיר יורד ככל שגדל מספר הסועדים. המחיר אחיד לכל סוגי השולחנות — <a href="/basari/">בשרי</a>, <a href="/halavi/">חלבי</a>, <a href="/hamburger/">המבורגר</a>, <a href="/schnitzel/">שניצל</a>, <a href="/tzimhoni/">צמחוני</a> — וכולל תפריט מלא עם שניצל, המבורגר, 9 סוגי מטוגנים, 8 סלטים, פירות העונה וקינוחי בוטיק.</p>

        <p>בהשוואה לקייטרינג רגיל, שולחן שוק מציע יחס מחיר-תוכן מצוין: תפריט של 30+ מנות ותוספות, הכנה טרייה ביום האירוע, הגעה, סידור, הגשה ופינוי — הכול כלול במחיר. <a href="/kasher/">כשרות למהדרין</a> ותעודת כשרות כלולות ללא תוספת.</p>

        <h3>מחיר לפי כמות אורחים</h3>

        <p>המחיר לאורח יורד ככל שגדל מספר הסועדים:</p>
        <ul>
          <li><strong>20 סועדים</strong> — 95 ₪ לאורח (1,900 ₪ סה"כ)</li>
          <li><strong>30 סועדים</strong> — 90 ₪ לאורח (2,700 ₪ סה"כ)</li>
          <li><strong>40 סועדים</strong> — 85 ₪ לאורח (3,400 ₪ סה"כ) — <strong>הכמות הפופולרית</strong></li>
          <li><strong>50 סועדים</strong> — 80 ₪ לאורח (4,000 ₪ סה"כ)</li>
          <li><strong>80+ סועדים</strong> — צרו קשר להנחת כמות נוספת</li>
        </ul>

        <h3>למה המחיר שווה?</h3>

        <p>80-95 ₪ לאורח כולל ארוחה מלאה — עיקריות, תוספות, סלטים, מטוגנים, פירות וקינוחים — עם הכנה טרייה ביום האירוע, הגעה לכל מקום בארץ, סידור מקצועי ופינוי. בקייטרינג רגיל, ארוחה ברמה דומה עולה לרוב יותר ומכילה פחות מגוון.</p>

        <p><strong>רוצים הצעת מחיר?</strong> 055-432-7900 או טופס באתר. שרית חוזרת תוך שעה עם הצעה מותאמת.</p>
      </div>
    </div>
  </section>

  <FAQ items={pricingFaq} title="שאלות נפוצות על מחירים" />

  <CTASection
    title="רוצים הצעת מחיר מדויקת?"
    subtitle="השאירו פרטים וקבלו הצעה מותאמת אישית תוך שעה"
    phone="055-432-7900"
  />
</BaseLayout>
