---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCardForm from '../components/HeroCardForm.astro';
---

<BaseLayout
  title="צור קשר — שולחן שוק"
  description="צרו קשר עם שולחן שוק לקבלת הצעת מחיר, ייעוץ או כל שאלה. טלפון, וואטסאפ וטופס."
>
  <HeroCardForm
    title="צרו קשר"
    subtitle="השאירו פרטים ונחזור אליכם תוך שעה — או פנו אלינו ישירות"
    formTitle="השאירו פרטים"
    backgroundImage="/images/hero/hero-05.webp"
    trustItems={['מענה תוך שעה', 'ייעוץ ללא התחייבות', 'פריסה ארצית', 'כשר למהדרין']}
  />

  <section class="py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-8 mt-8">
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-border/50">
          <h3 class="font-bold text-dark mb-4 text-lg">פרטי קשר</h3>
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <span class="text-brand-600 text-xl">📞</span>
              <a href="tel:055-432-7900" class="text-dark font-semibold hover:text-brand-600 transition-colors" dir="ltr">055-432-7900</a>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-brand-600 text-xl">✉️</span>
              <a href="mailto:info@shulhan-shuk.co.il" class="text-dark font-semibold hover:text-brand-600 transition-colors" dir="ltr">info@shulhan-shuk.co.il</a>
            </div>
          </div>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-border/50">
          <h3 class="font-bold text-dark mb-4 text-lg">שעות פעילות</h3>
          <div class="space-y-2 text-muted">
            <p>ראשון - חמישי: 08:00 - 20:00</p>
            <p>שישי: 08:00 - 14:00</p>
            <p>שבת: סגור</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
