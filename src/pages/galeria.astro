---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import CTASection from '../components/CTASection.astro';

const galleryImages = [
  { src: '/images/gallery/img-01.webp', alt: 'שולחן שוק בשרי מרשים לאירוע' },
  { src: '/images/gallery/img-04.webp', alt: 'שולחן שוק ארוך עם מגוון מנות' },
  { src: '/images/gallery/img-06.webp', alt: 'שולחן שוק חגיגי' },
  { src: '/images/gallery/img-10.webp', alt: 'שולחן שוק עם ירקות טריים' },
  { src: '/images/gallery/img-15.webp', alt: 'שולחן שוק ליום הולדת' },
  { src: '/images/gallery/img-20.webp', alt: 'מגש ירקות טריים צבעוני' },
  { src: '/images/gallery/img-25.webp', alt: 'עיצוב שולחן שוק פרימיום' },
  { src: '/images/gallery/img-30.webp', alt: 'שולחן שוק לבר מצווה' },
  { src: '/images/gallery/img-35.webp', alt: 'שולחן שוק בשרי מלא' },
  { src: '/images/gallery/img-40.webp', alt: 'שולחן שוק לאירוע' },
  { src: '/images/gallery/img-50.webp', alt: 'שולחן שוק למסיבת רווקות' },
  { src: '/images/gallery/img-60.webp', alt: 'שולחן שוק לאירוע חברה' },
  { src: '/images/gallery/img-65.webp', alt: 'סלטים טריים על שולחן שוק' },
  { src: '/images/gallery/img-70.webp', alt: 'שולחן שוק מוכן להגשה' },
  { src: '/images/gallery/img-75.webp', alt: 'שולחן שוק מעוצב' },
  { src: '/images/gallery/img-80.webp', alt: 'שולחן שוק חלבי לשבת' },
];
---

<BaseLayout
  title="גלריה — תמונות שולחנות שוק מאירועים"
  description="גלריית תמונות מאירועים אמיתיים — שולחנות שוק בשרי, חלבי, המבורגר, קינוחים ועוד. ראו את השולחנות שלנו."
>
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4">
      <h1 class="text-3xl md:text-4xl font-heading font-bold text-dark mb-3 text-center">גלריה</h1>
      <p class="text-muted text-center mb-4 max-w-2xl mx-auto">תמונות מאירועים אמיתיים — כל שולחן שוק שאנחנו מכינים הוא יצירה</p>
    </div>
  </section>
  <GalleryGrid images={galleryImages} title="" />
  <CTASection phone="055-432-7900" primaryHref="/tzor-kesher/" />
</BaseLayout>
