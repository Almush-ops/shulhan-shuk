---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTASection from '../components/CTASection.astro';
import TrustBarLogos from '../components/TrustBarLogos.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  mainEntity: {
    '@type': 'FoodService',
    name: 'שולחן שוק',
    description: 'שירות קייטרינג שולחנות שוק כשר למהדרין לכל סוג אירוע. פריסה ארצית, הכנה טרייה ביום האירוע.',
    url: 'https://shulhan-shuk.co.il',
    telephone: '+972-55-432-7900',
    founder: {
      '@type': 'Person',
      name: 'שרית',
      jobTitle: 'בעלים ומנהלת',
      image: 'https://shulhan-shuk.co.il/images/sarit.webp',
    },
    areaServed: { '@type': 'Country', name: 'Israel' },
    priceRange: '₪₪',
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'שולחנות שוק',
      itemListElement: [
        { '@type': 'Offer', itemOffered: { '@type': 'FoodService', name: 'שולחן שוק בשרי' } },
        { '@type': 'Offer', itemOffered: { '@type': 'FoodService', name: 'שולחן שוק חלבי' } },
        { '@type': 'Offer', itemOffered: { '@type': 'FoodService', name: 'שולחן שוק המבורגר' } },
      ],
    },
  },
};
---

<BaseLayout
  title="אודות שולחן שוק — הסיפור שלנו | שרית, קייטרינג שולחנות שוק"
  description="הכירו את שרית, הבעלים של שולחן שוק — שירות קייטרינג שולחנות שוק כשר למהדרין לכל אירוע. הכנה טרייה ביום האירוע, פריסה ארצית, מחירים שקופים."
>
  <!-- Hero: Sarit Photo + Intro -->
  <section class="py-16 md:py-24 bg-gradient-to-bl from-brand-50 via-white to-surface">
    <div class="max-w-7xl mx-auto px-4">
      <Breadcrumbs items={[{ label: 'אודות' }]} />
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center mt-6">
        <!-- Text side -->
        <div>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading text-dark mb-6 leading-tight">
            הכירו את <span class="text-brand-600">שרית</span> — הלב של שולחן שוק
          </h1>
          <p class="text-lg text-muted leading-relaxed mb-6">
            מאחורי כל שולחן שוק עומדת שרית — שמלווה כל אירוע באופן אישי, מהפנייה הראשונה ועד הפינוי. שרית בונה תפריט מותאם, מוודאת שכל פרט במקום, ודואגת שהשולחן ייראה ויטעם בדיוק כמו שצריך.
          </p>
          <p class="text-muted leading-relaxed mb-8">
            את <strong class="text-dark">שולחן שוק</strong> הקימה שרית מתוך אהבה לאוכל ישראלי, לאירוח ולאנשים. היא מאמינה ששולחן שוק טוב הוא לא סתם אוכל — זו חוויה שמחברת אנשים, יוצרת אווירה ומשאירה זיכרונות. כל אירוע שהיא עושה, היא עושה בדיוק כאילו זה האירוע שלה.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="tel:0554327900" class="inline-flex items-center gap-2 px-6 py-3 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-700 transition-colors shadow-md">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              055-432-7900
            </a>
            <a href="https://wa.me/972554327900" class="inline-flex items-center gap-2 px-6 py-3 border-2 border-fresh-600 text-fresh-700 font-semibold rounded-lg hover:bg-fresh-50 transition-colors">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.327 0-4.542-.674-6.437-1.912l-.46-.298-2.64.885.885-2.64-.298-.46A9.955 9.955 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/></svg>
              שליחת הודעה
            </a>
          </div>
        </div>
        <!-- Photo side -->
        <div class="flex justify-center lg:justify-end">
          <div class="relative">
            <div class="absolute -inset-4 bg-brand-200/30 rounded-3xl transform rotate-3"></div>
            <img
              src="/images/sarit.webp"
              alt="שרית — הבעלים של שולחן שוק"
              class="relative rounded-2xl shadow-xl w-80 md:w-96 object-cover"
              width="640"
              height="641"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="py-10 bg-brand-600 text-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-3xl md:text-4xl font-bold mb-1">30+</div>
          <div class="text-brand-100 text-sm">מנות ותוספות בכל שולחן</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold mb-1">14</div>
          <div class="text-brand-100 text-sm">אזורי שירות בכל הארץ</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold mb-1">8</div>
          <div class="text-brand-100 text-sm">סוגי שולחנות שוק</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold mb-1">100%</div>
          <div class="text-brand-100 text-sm">כשר למהדרין</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-heading text-dark mb-8 text-center">הסיפור שלנו</h2>
      <div class="prose max-w-none">
        <p>שולחן שוק נולד מהמקום הכי טבעי — מהרצון לשתף אוכל טוב עם אנשים. שרית תמיד אהבה לארח, לבשל ולסדר שולחנות מרשימים. כשהיא ראתה כמה אנשים מתלהבים מהשולחנות שהיא מכינה — היא הבינה שזה מה שהיא רוצה לעשות.</p>

        <p>היום, <strong>שולחן שוק</strong> מספק שולחנות שוק לכל סוג אירוע — מ<a href="/yom-huledet/">ימי הולדת</a> אינטימיים ועד <a href="/eruey-hevra/">אירועי חברה</a> גדולים, מ<a href="/bar-mitzva/">בר מצוות</a> מרגשות ועד <a href="/mesibat-ravakot/">מסיבות רווקות</a> מטורפות. כל שולחן מוכן טרי ביום האירוע, מחומרי גלם איכותיים ובהשגחת כשרות מהדרין.</p>

        <p>מה שמייחד את שולחן שוק הוא הגישה האישית. שרית מלווה כל אירוע מהרגע הראשון — שיחת ייעוץ, התאמת <a href="/tafrit/">תפריט</a>, הכנה, הגעה, סידור ועיצוב השולחן, הגשה ופינוי. כל הפרטים הקטנים שהופכים שולחן שוק מאוכל — לחוויה.</p>
      </div>
    </div>
  </section>

  <!-- What Makes Us Different -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-heading text-dark mb-3 text-center">מה מייחד את שולחן שוק?</h2>
      <p class="text-muted text-center mb-12 max-w-2xl mx-auto">הערכים שמנחים אותנו בכל אירוע</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        <div class="bg-white p-6 rounded-2xl shadow-sm hover:shadow-md transition-shadow border border-border/30">
          <div class="w-12 h-12 rounded-xl bg-fresh-500/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-fresh-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="font-bold text-dark mb-2">טריות ללא פשרות</h3>
          <p class="text-sm text-muted">כל המנות מוכנות ביום האירוע. לא קפוא, לא מחומם מראש. שניצלים פריכים, סלטים טריים, מטוגנים חמים ופירות חתוכים — הכל בדיוק כמו שצריך להיות.</p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm hover:shadow-md transition-shadow border border-border/30">
          <div class="w-12 h-12 rounded-xl bg-brand-100 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="font-bold text-dark mb-2">כשר למהדרין</h3>
          <p class="text-sm text-muted">תעודת כשרות מהדרין, השגחה צמודה, חומרי גלם מהודרים והפרדה מלאה בין בשרי לחלבי. בלי תוספת מחיר — כי ככה צריך להיות.</p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm hover:shadow-md transition-shadow border border-border/30">
          <div class="w-12 h-12 rounded-xl bg-fresh-500/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-fresh-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
          </div>
          <h3 class="font-bold text-dark mb-2">מחירים שקופים</h3>
          <p class="text-sm text-muted"><a href="/mehirim/" class="text-brand-600 hover:underline">80-95 ₪ לאורח</a> — תלוי בכמות הסועדים. בלי הפתעות, בלי עלויות נסתרות, בלי אותיות קטנות. מה שסוכם — זה מה שמשלמים.</p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm hover:shadow-md transition-shadow border border-border/30">
          <div class="w-12 h-12 rounded-xl bg-brand-100 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="font-bold text-dark mb-2">פריסה ארצית</h3>
          <p class="text-sm text-muted">מגיעים לכל מקום בישראל — מקריית שמונה ועד אילת. <a href="/tel-aviv/" class="text-brand-600 hover:underline">תל אביב</a>, <a href="/haifa/" class="text-brand-600 hover:underline">חיפה</a>, <a href="/yerushalayim/" class="text-brand-600 hover:underline">ירושלים</a>, <a href="/beer-sheva/" class="text-brand-600 hover:underline">באר שבע</a> ולכל ישוב.</p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm hover:shadow-md transition-shadow border border-border/30">
          <div class="w-12 h-12 rounded-xl bg-fresh-500/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-fresh-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
          </div>
          <h3 class="font-bold text-dark mb-2">ליווי אישי מקצה לקצה</h3>
          <p class="text-sm text-muted">שרית מלווה כל אירוע באופן אישי. ייעוץ, בניית תפריט, הכנה, הגעה למקום, סידור ועיצוב, הגשה ופינוי — אתם רק נהנים מהאירוע.</p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm hover:shadow-md transition-shadow border border-border/30">
          <div class="w-12 h-12 rounded-xl bg-brand-100 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
          </div>
          <h3 class="font-bold text-dark mb-2">מגוון לכל טעם</h3>
          <p class="text-sm text-muted"><a href="/basari/" class="text-brand-600 hover:underline">בשרי</a>, <a href="/halavi/" class="text-brand-600 hover:underline">חלבי</a>, <a href="/hamburger/" class="text-brand-600 hover:underline">המבורגר</a>, <a href="/schnitzel/" class="text-brand-600 hover:underline">שניצל</a>, <a href="/kinuchim/" class="text-brand-600 hover:underline">קינוחים</a>, <a href="/metugganim/" class="text-brand-600 hover:underline">מטוגנים</a>, <a href="/tzimhoni/" class="text-brand-600 hover:underline">צמחוני</a> ו<a href="/kasher/" class="text-brand-600 hover:underline">כשר למהדרין</a>. התפריט ניתן להתאמה אישית.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Kashrut Certificate -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-2xl md:text-3xl font-heading text-dark mb-6">תעודת כשרות מהדרין</h2>
          <p class="text-muted leading-relaxed mb-4">
            כל השולחנות שלנו מוכנים תחת השגחת כשרות מהדרין צמודה. אנחנו עובדים עם חומרי גלם מהודרים בלבד, שומרים על הפרדה מלאה בין בשרי לחלבי, ומקפידים על כל הלכה.
          </p>
          <p class="text-muted leading-relaxed mb-6">
            הכשרות לא בתוספת מחיר — היא חלק בלתי נפרד מהשירות שלנו. לכל אירוע מגיעה תעודת כשרות מהדרין בתוקף.
          </p>
          <a href="/kasher/" class="inline-flex items-center gap-2 text-brand-600 font-semibold hover:underline">
            לפרטים נוספים על הכשרות
            <svg class="w-4 h-4 rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
          </a>
        </div>
        <div class="flex justify-center">
          <div class="bg-white p-4 rounded-2xl shadow-lg border border-border/50 max-w-xs">
            <img
              src="/images/kashrut/kashrut-certificate.webp"
              alt="תעודת כשרות מהדרין — שולחן שוק"
              class="rounded-lg w-full"
              width="400"
              height="560"
              loading="lazy"
            />
            <p class="text-center text-xs text-muted mt-3">תעודת כשרות מהדרין בתוקף</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-heading text-dark mb-8 text-center">סוגי שולחנות שוק</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href="/basari/" class="group p-4 bg-white rounded-xl shadow-sm hover:shadow-md transition-all text-center border border-border/30">
          <div class="text-lg font-bold text-dark group-hover:text-brand-600 transition-colors">בשרי</div>
          <p class="text-xs text-muted mt-1">שניצל, המבורגר, מטוגנים</p>
        </a>
        <a href="/halavi/" class="group p-4 bg-white rounded-xl shadow-sm hover:shadow-md transition-all text-center border border-border/30">
          <div class="text-lg font-bold text-dark group-hover:text-brand-600 transition-colors">חלבי</div>
          <p class="text-xs text-muted mt-1">גבינות, מאפים, סלטים</p>
        </a>
        <a href="/hamburger/" class="group p-4 bg-white rounded-xl shadow-sm hover:shadow-md transition-all text-center border border-border/30">
          <div class="text-lg font-bold text-dark group-hover:text-brand-600 transition-colors">המבורגר</div>
          <p class="text-xs text-muted mt-1">המבורגרים טריים בלחמניות</p>
        </a>
        <a href="/schnitzel/" class="group p-4 bg-white rounded-xl shadow-sm hover:shadow-md transition-all text-center border border-border/30">
          <div class="text-lg font-bold text-dark group-hover:text-brand-600 transition-colors">שניצל</div>
          <p class="text-xs text-muted mt-1">שניצלים פריכים וצ'יפס</p>
        </a>
        <a href="/kinuchim/" class="group p-4 bg-white rounded-xl shadow-sm hover:shadow-md transition-all text-center border border-border/30">
          <div class="text-lg font-bold text-dark group-hover:text-brand-600 transition-colors">קינוחים</div>
          <p class="text-xs text-muted mt-1">קינוחי בוטיק ופירות</p>
        </a>
        <a href="/metugganim/" class="group p-4 bg-white rounded-xl shadow-sm hover:shadow-md transition-all text-center border border-border/30">
          <div class="text-lg font-bold text-dark group-hover:text-brand-600 transition-colors">מטוגנים</div>
          <p class="text-xs text-muted mt-1">9 סוגי מטוגנים חמים</p>
        </a>
        <a href="/tzimhoni/" class="group p-4 bg-white rounded-xl shadow-sm hover:shadow-md transition-all text-center border border-border/30">
          <div class="text-lg font-bold text-dark group-hover:text-brand-600 transition-colors">צמחוני</div>
          <p class="text-xs text-muted mt-1">חומוס, פלאפל, סלטים</p>
        </a>
        <a href="/kasher/" class="group p-4 bg-white rounded-xl shadow-sm hover:shadow-md transition-all text-center border border-border/30">
          <div class="text-lg font-bold text-dark group-hover:text-brand-600 transition-colors">כשר למהדרין</div>
