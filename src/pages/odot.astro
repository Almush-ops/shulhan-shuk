---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout
  title="אודות שולחן שוק — קייטרינג שולחנות שוק כשר למהדרין"
  description="הכירו את שולחן שוק — שירות קייטרינג שולחנות שוק מקצועי לכל אירוע. כשר למהדרין, הכנה טרייה ביום האירוע, פריסה ארצית."
>
  <section class="py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4">
      <Breadcrumbs items={[{ label: 'אודות' }]} />
      <h1 class="text-3xl md:text-4xl font-heading text-dark mb-8">אודות שולחן שוק</h1>

      <div class="prose max-w-none">
        <p><strong>שולחן שוק</strong> מתמחה בהכנה והגשה של שולחנות שוק מרשימים לכל סוג אירוע — <a href="/yom-huledet/">ימי הולדת</a>, <a href="/bar-mitzva/">בר/בת מצווה</a>, <a href="/hatuna/">חתונות</a>, <a href="/mesibat-ravakot/">מסיבות רווקות</a>, <a href="/hina/">חינות</a>, <a href="/eruey-hevra/">אירועי חברה</a> ו<a href="/shabat/">ארוחות שבת</a>. כל שולחן מוכן טרי ביום האירוע מחומרי גלם איכותיים, ומוגש בסגנון שוק אוכל ישראלי — צבעוני, עשיר ומזמין.</p>

        <p>מאחורי כל שולחן שוק עומדת <strong>שרית</strong>, שמלווה כל אירוע מהפנייה הראשונה ועד הפינוי. שרית בונה תפריט מותאם, מוודאת שכל פרט במקום, ודואגת שהשולחן ייראה ויטעם בדיוק כמו שצריך.</p>

        <h2>מה מיוחד בשולחן שוק?</h2>

        <p>שולחן שוק הוא לא סתם קייטרינג — זו חוויה. שולחן ארוך ומרשים, עמוס ב-30+ מנות ותוספות, שמביא את האווירה של שוק האוכל הישראלי ישר לאירוע שלכם. <a href="/tafrit/">התפריט</a> כולל שניצל פריך בלחמניות, המבורגר טרי, 9 סוגי מטוגנים חמים, 8 סלטים טריים, פירות העונה וקינוחי בוטיק.</p>

        <h2>הערכים שלנו</h2>

        <ul>
          <li><strong>טריות</strong> — כל המנות מוכנות ביום האירוע. לא קפוא, לא מחומם מראש. שניצלים פריכים, סלטים טריים, מטוגנים חמים ופירות חתוכים</li>
          <li><strong>כשרות למהדרין</strong> — כל השולחנות <a href="/kasher/">כשרים למהדרין</a> — תעודת כשרות, חומרי גלם מהודרים, השגחה צמודה. ללא תוספת מחיר</li>
          <li><strong>שקיפות</strong> — <a href="/mehirim/">מחירים</a> ברורים מראש: 80-95 ₪ לאורח. בלי הפתעות ובלי עלויות נסתרות</li>
          <li><strong>שירות מקצה לקצה</strong> — ייעוץ, בניית תפריט, הכנה, הגעה, סידור, הגשה ופינוי. אתם רק נהנים</li>
          <li><strong>פריסה ארצית</strong> — מגיעים לכל מקום בישראל: <a href="/tel-aviv/">תל אביב והמרכז</a>, <a href="/haifa/">חיפה</a>, <a href="/yerushalayim/">ירושלים</a>, <a href="/beer-sheva/">באר שבע</a> ועוד</li>
        </ul>

        <h2>סוגי שולחנות</h2>

        <p>אנחנו מציעים מגוון סוגי שולחנות שוק שמתאימים לכל טעם ולכל אירוע:</p>

        <ul>
          <li><a href="/basari/"><strong>שולחן שוק בשרי</strong></a> — שניצל, המבורגר, מטוגנים, סלטים, פירות וקינוחים</li>
          <li><a href="/halavi/"><strong>שולחן שוק חלבי</strong></a> — גבינות, מאפים, סלטי שף, פירות וקינוחים</li>
          <li><a href="/hamburger/"><strong>שולחן שוק המבורגר</strong></a> — המבורגרים טריים בלחמניות עם כל התוספות</li>
          <li><a href="/schnitzel/"><strong>שולחן שוק שניצל</strong></a> — שניצלים פריכים עם צ'יפס ומטוגנים</li>
          <li><a href="/tzimhoni/"><strong>שולחן שוק צמחוני</strong></a> — חומוס, פלאפל, סלטים, מטוגנים ללא בשר</li>
          <li><a href="/metugganim/"><strong>שולחן שוק מטוגנים</strong></a> — 9 סוגי מטוגנים חמים ופריכים</li>
          <li><a href="/kinuchim/"><strong>שולחן שוק קינוחים</strong></a> — קינוחי בוטיק ופירות העונה</li>
        </ul>

        <h2>פרטי קשר</h2>

        <ul>
          <li><strong>טלפון</strong>: <a href="tel:0554327900">055-432-7900</a></li>
          <li><strong>וואטסאפ</strong>: <a href="https://wa.me/972554327900">לחצו לשליחת הודעה</a></li>
          <li><strong>כשרות</strong>: כשר למהדרין</li>
          <li><strong>אזור שירות</strong>: כל הארץ</li>
          <li><strong>מחירים</strong>: 80-95 ₪ לאורח (<a href="/mehirim/">למחירון</a>)</li>
        </ul>

        <!-- Placeholder for owner bio + photo - to be added when received from client -->
      </div>
    </div>
  </section>

  <ProcessSteps />
  <CTASection phone="055-432-7900" />
</BaseLayout>
