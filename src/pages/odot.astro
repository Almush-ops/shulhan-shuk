---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTASection from '../components/CTASection.astro';
import TrustBarLogos from '../components/TrustBarLogos.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  mainEntity: {
    '@type': 'FoodService',
    name: 'שולחן שוק',
    description: 'שירות קייטרינג שולחנות שוק כשר למהדרין לכל סוג אירוע. פריסה ארצית, הכנה טרייה ביום האירוע.',
    url: 'https://shulhan-shuk.co.il',
    telephone: '+972-55-432-7900',
    founder: {
      '@type': 'Person',
      name: 'שרית דברשוילי',
      jobTitle: 'מייסדת ושפית ראשית',
      image: 'https://shulhan-shuk.co.il/images/sarit.webp',
      description: 'שפית קייטרינג עם למעלה מ-8 שנות ניסיון בהכנת שולחנות שוק לאירועים. מלווה כל אירוע באופן אישי מהייעוץ הראשוני ועד הפינוי.',
      knowsAbout: ['קייטרינג שולחנות שוק', 'בישול ישראלי', 'אוכל כשר למהדרין', 'עיצוב שולחנות אירועים'],
    },
    foundingDate: '2018',
    areaServed: { '@type': 'Country', name: 'Israel' },
    priceRange: '₪₪',
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'שולחנות שוק',
      itemListElement: [
        { '@type': 'Offer', itemOffered: { '@type': 'FoodService', name: 'שולחן שוק בשרי' } },
        { '@type': 'Offer', itemOffered: { '@type': 'FoodService', name: 'שולחן שוק חלבי' } },
        { '@type': 'Offer', itemOffered: { '@type': 'FoodService', name: 'שולחן שוק המבורגר' } },
      ],
    },
  },
};
---

<BaseLayout
  title="אודות שולחן שוק — הסיפור של שרית | קייטרינג שולחנות שוק"
  description="הכירו את שרית דברשוילי, מייסדת שולחן שוק — למעלה מ-8 שנים ו-1,200 אירועים של שולחנות שוק כשר למהדרין. מהמטבח של סבתא בבאר שבע לשולחנות שוק בכל הארץ."
>
  <!-- Hero: Sarit Photo + Intro -->
  <section class="py-16 md:py-24 bg-gradient-to-bl from-brand-50 via-white to-surface">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <!-- Text side -->
        <div>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading text-dark mb-6 leading-tight">
            הכירו את <span class="text-brand-600">שרית</span> — הלב והנשמה של שולחן שוק
          </h1>
          <p class="text-lg text-muted leading-relaxed mb-4">
            בבית של שרית תמיד היו שני דברים: הרבה אנשים והרבה אוכל. היא גדלה בבית גאורגי חם בבאר שבע, עם סבתא נינו שהכינה חצ'פורי וחינקאלי לכל השכונה ואמא שלא נתנה לאף אחד לצאת מהבית בלי לאכול. בתרבות הגאורגית יש מסורת של "סופרא" — שולחן גדוש שמכבד כל אורח. המטבח היה הסלון, השולחן היה הלב, והאוכל היה השפה שבה דיברו על הכל.
          </p>
          <p class="text-muted leading-relaxed mb-4">
            אחרי שירות צבאי ולימודי ניהול קולינרי, שרית עבדה בכמה מטבחי קייטרינג — אבל מהר מאוד הבינה שהיא רוצה לעשות את זה <strong class="text-dark">אחרת</strong>. לא פס ייצור של מגשים, אלא משהו אישי. משהו שמרגיש כמו הבית שלה.
          </p>
          <p class="text-muted leading-relaxed mb-8">
            ב-2018 היא הקימה את <strong class="text-dark">שולחן שוק</strong>. מאז — למעלה מ-<strong class="text-dark">1,200 אירועים</strong>, והיא עדיין מגיעה לכל אחד מהם באופן אישי. מסדרת את השולחן, טועמת מכל מנה, מוודאת שהכל מושלם. "אני לא שולחת צוות", היא אומרת, "אני <em>באה</em>."
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="tel:0554327900" class="inline-flex items-center gap-2 px-6 py-3 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-700 transition-colors shadow-md">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              055-432-7900
            </a>
          </div>
        </div>
        <!-- Photo side -->
        <div class="flex justify-center lg:justify-end">
          <div class="relative">
            <div class="absolute -inset-4 bg-brand-200/30 rounded-3xl transform rotate-3"></div>
            <img
              src="/images/sarit.webp"
              alt="שרית דברשוילי — מייסדת שולחן שוק, שפית קייטרינג שולחנות שוק"
              class="relative rounded-2xl shadow-xl w-80 md:w-96 object-cover"
              width="640"
              height="641"
            />
            <div class="absolute -bottom-3 -right-3 bg-white px-4 py-2 rounded-xl shadow-lg border border-border/50">
              <p class="text-sm font-bold text-brand-600">8+ שנות ניסיון</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="py-10 bg-brand-600 text-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-3xl md:text-4xl font-bold mb-1">1,200+</div>
          <div class="text-brand-100 text-sm">אירועים מוצלחים</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold mb-1">8+</div>
          <div class="text-brand-100 text-sm">שנות ניסיון</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold mb-1">45,000+</div>
          <div class="text-brand-100 text-sm">סועדים מרוצים</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold mb-1">100%</div>
          <div class="text-brand-100 text-sm">ליווי אישי של שרית</div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Journey -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-heading text-dark mb-10 text-center">הדרך שלי</h2>
      <div class="space-y-12">
        <!-- Chapter 1: Childhood -->
        <div class="relative pr-8 border-r-2 border-brand-200">
          <div class="absolute top-1 -right-2.5 w-5 h-5 rounded-full bg-brand-500 border-2 border-white"></div>
          <h3 class="font-bold text-dark text-lg mb-2">המטבח של סבתא נינו</h3>
          <p class="text-muted leading-relaxed">
            כשאני חושבת מאיפה זה התחיל, אני תמיד חוזרת לאותו מטבח קטן בשכונה ד' בבאר שבע. סבתא נינו הייתה מתחילה לבשל ביום חמישי בצהריים — חצ'פורי, חינקאלי, קציצות טבעת ומרק שעועית. עד שישי בערב הדירה הייתה מלאה באנשים. שכנים, בני דודים, חברים של חברים. לא היה צריך הזמנה — מי שהגיע, אכל. בגאורגית קוראים לזה "סטומריספא" — שהשולחן תמיד פתוח.
          </p>
          <p class="text-muted leading-relaxed mt-3">
            אני זוכרת את עצמי בת 8, עומדת על כיסא ליד השיש, עוזרת לסבתא לקפל חינקאלי. היא הייתה אומרת לי: "שריתי, את לא מבשלת רק אוכל — את מבשלת אהבה. ותמיד תכיני יותר ממה שצריך, כי תמיד יבוא מישהו שלא ציפית לו." עד היום אני מכינה יותר ממה שצריך.
          </p>
        </div>

        <!-- Chapter 2: The Turn -->
        <div class="relative pr-8 border-r-2 border-brand-200">
          <div class="absolute top-1 -right-2.5 w-5 h-5 rounded-full bg-brand-500 border-2 border-white"></div>
          <h3 class="font-bold text-dark text-lg mb-2">הרגע שהכל השתנה</h3>
          <p class="text-muted leading-relaxed">
            אחרי הצבא למדתי ניהול קולינרי, ואז עבדתי כמה שנים במטבחי קייטרינג. המנות היו טובות, אבל הרגשתי שמשהו חסר. הכל היה מסודר מדי, קר מדי, "מקצועי" מדי. חסר היה הלב — האוכל היה טעים, אבל השולחן לא הרגיש כמו בית.
          </p>
          <p class="text-muted leading-relaxed mt-3">
            ואז הגיע האירוע שהפך את הכל. חברה טובה ביקשה ממני לעזור לה לארגן יום הולדת 40 לבעל שלה. במקום קייטרינג רגיל, בניתי שולחן שוק — שמתי את הכל על שולחן אחד ארוך, בשפע, עם צבעים, ריחות, ועיצוב שמזכיר שוק ישראלי. האורחים היו בהלם. לא מהאוכל — מהחוויה. הם צילמו, הם טעמו, הם חזרו בשביל עוד. תוך שבוע קיבלתי 4 טלפונים ממכרים שרצו "בדיוק את אותו דבר".
          </p>
        </div>

        <!-- Chapter 3: Building -->
        <div class="relative pr-8 border-r-2 border-brand-200">
          <div class="absolute top-1 -right-2.5 w-5 h-5 rounded-full bg-brand-500 border-2 border-white"></div>
          <h3 class="font-bold text-dark text-lg mb-2">ב-2018 נולד "שולחן שוק"</h3>
          <p class="text-muted leading-relaxed">
            באותו רגע הבנתי שזה מה שאני רוצה לעשות. לא מגשים עטופים בצלופן — שולחנות שוק חיים, צבעוניים, שופעים. שולחנות שגורמים לאנשים להתקרב, לטעום, לשתף, לצחוק. ב-2018 הקמתי רשמית את <strong>"שולחן שוק"</strong> — ומהאירוע הראשון ידעתי שזה הדבר שלי.
          </p>
          <p class="text-muted leading-relaxed mt-3">
            ההתחלה הייתה מהמטבח של הבית. קנייה בשוק הסיטונאי ב-5 בבוקר, בישול כל היום, הובלה בערב. האירועים הראשונים היו 20-30 אורחים, בעיקר ימי הולדת ומסיבות בית. אבל מפה לאוזן עבד — כל אירוע הביא עוד שניים. תוך שנה עברתי למטבח מקצועי עם השגחת כשרות מהדרין, וההזמנות לא הפסיקו.
          </p>
        </div>

        <!-- Chapter 4: Today -->
        <div class="relative pr-8">
          <div class="absolute top-1 -right-2.5 w-5 h-5 rounded-full bg-fresh-500 border-2 border-white"></div>
          <h3 class="font-bold text-dark text-lg mb-2">היום — למעלה מ-1,200 אירועים אחרי</h3>
          <p class="text-muted leading-relaxed">
            היום אני מכינה שולחנות שוק לכל סוגי האירועים — מ<a href="/yom-huledet/" class="text-brand-600 hover:underline">ימי הולדת</a> קטנים ואינטימיים ל-20 אורחים, דרך <a href="/bar-mitzva/" class="text-brand-600 hover:underline">בר מצוות</a> ו<a href="/mesibat-ravakot/" class="text-brand-600 hover:underline">מסיבות רווקות</a>, ועד <a href="/eruey-hevra/" class="text-brand-600 hover:underline">אירועי חברה</a> גדולים ל-200 סועדים. עבדתי עם ארגונים כמו שופרסל, מטריקס, אגד ואפילו משרד ראש הממשלה.
          </p>
          <p class="text-muted leading-relaxed mt-3">
            ואחרי 1,200 אירועים ולמעלה מ-45,000 סועדים — אני עדיין מגיעה לכל אירוע. עדיין טועמת מכל מנה. עדיין מסדרת כל שולחן במו ידיי. אנשים שואלים אותי למה אני לא פשוט שולחת צוות. התשובה פשוטה: כי השולחן הזה הוא לא סתם עבודה בשבילי. זה מה שאני הכי אוהבת לעשות בעולם.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy / Quote -->
  <section class="py-16 md:py-20 bg-brand-50/50">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <svg class="w-10 h-10 text-brand-300 mx-auto mb-6" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
      <blockquote class="text-xl md:text-2xl font-heading text-dark leading-relaxed mb-6">
        "שולחן שוק טוב הוא לא סתם אוכל — זו חוויה שמחברת אנשים. כשאורחים מתקרבים לשולחן, טועמים, מחייכים ואומרים 'וואו' — בשביל הרגע הזה אני קמה בבוקר."
      </blockquote>
      <div class="flex items-center justify-center gap-3">
        <img src="/images/sarit.webp" alt="שרית" class="w-12 h-12 rounded-full object-cover" width="48" height="48" loading="lazy" />
        <div class="text-right">
          <p class="font-bold text-dark">שרית דברשוילי</p>
          <p class="text-sm text-muted">מייסדת שולחן שוק</p>
        </div>
      </div>
    </blockquote>
    </div>
  </section>

  <!-- What I Believe -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-heading text-dark mb-4 text-center">העקרונות שלי</h2>
      <p class="text-muted text-center mb-12 max-w-2xl mx-auto">שלושה דברים שאני לא מתפשרת עליהם — באף אירוע, בשום מצב</p>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl bg-fresh-500/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-fresh-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="font-bold text-dark text-lg mb-3">הכל טרי. נקודה.</h3>
          <p class="text-sm text-muted leading-relaxed">אני קונה חומרי גלם בשוק הסיטונאי בלילה שלפני האירוע. בבוקר מתחילים לבשל, ובשעת האירוע הכל מגיע חם וטרי. שום דבר לא קפוא, שום דבר לא מחומם מחדש. <a href="/tafrit/" class="text-brand-600 hover:underline">כל המנות בתפריט</a> — מהשניצלים ועד הסלטים — מוכנות ביום.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl bg-brand-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
          </div>
          <h3 class="font-bold text-dark text-lg mb-3">אני באה. בעצמי.</h3>
          <p class="text-sm text-muted leading-relaxed">אני לא שולחת מישהו במקומי. אני מגיעה לכל אירוע, מסדרת את השולחן, מוודאת שהכל במקום, מגישה ובסוף — מפנה. בגלל זה אני מגבילה את עצמי לאירוע אחד ביום. כי כשאני עושה משהו — אני עושה אותו כמו שצריך.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl bg-fresh-500/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-fresh-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
          </div>
          <h3 class="font-bold text-dark text-lg mb-3">בלי הפתעות במחיר</h3>
          <p class="text-sm text-muted leading-relaxed"><a href="/mehirim/" class="text-brand-600 hover:underline">80-95 ₪ לאורח</a> — תלוי רק בכמות הסועדים. המחיר כולל הכל: חומרי גלם, בישול, הובלה, סידור, עיצוב, הגשה ופינוי. בלי אותיות קטנות ובלי "תוספות" שצצות ברגע האחרון. מה שסוכם — זה מה שמשלמים.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What Makes Us Different (expanded) -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-heading text-dark mb-3 text-center">מה עוד חשוב לדעת?</h2>
      <p class="text-muted text-center mb-12 max-w-2xl mx-auto">כל מה שהופך את שולחן שוק לבחירה הנכונה</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        <div class="bg-white p-6 rounded-2xl shadow-sm hover:shadow-md transition-shadow border border-border/30">
          <div class="w-12 h-12 rounded-xl bg-brand-100 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="font-bold text-dark mb-2">כשר למהדרין — ללא תוספת</h3>
