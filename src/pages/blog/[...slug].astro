---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  ...(post.data.image ? { image: `https://shulhan-shuk.co.il${post.data.image}` } : {}),
  author: { '@type': 'Organization', name: 'שולחן שוק', url: 'https://shulhan-shuk.co.il' },
  publisher: { '@type': 'Organization', name: 'שולחן שוק', url: 'https://shulhan-shuk.co.il' },
};

const breadcrumbItems = [
  { label: 'בלוג', href: '/blog/' },
  { label: post.data.title },
];
---

<BaseLayout
  title={`${post.data.title} | שולחן שוק`}
  description={post.data.description}
  ogType="article"
  ogImage={post.data.image}
>
  <section class="py-12 md:py-16">
    <div class="max-w-3xl mx-auto px-4">
      <Breadcrumbs items={breadcrumbItems} />
      <h1 class="text-3xl md:text-4xl font-heading font-bold text-dark mb-8">{post.data.title}</h1>
      <div class="prose max-w-none">
        <Content />
      </div>
    </div>
  </section>

  {post.data.faq && post.data.faq.length > 0 && (
    <section class="bg-surface">
      <FAQ items={post.data.faq} />
    </section>
  )}

  <CTASection phone="055-432-7900" primaryHref="/tzor-kesher/" />
  <SchemaOrg schema={articleSchema} />
</BaseLayout>
