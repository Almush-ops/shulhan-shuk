---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FAQ from '../components/FAQ.astro';
import CTASection from '../components/CTASection.astro';

const faqItems = [
  { question: 'מה זה שולחן שוק?', answer: 'שולחן שוק הוא קונספט קייטרינג שבו האוכל מוגש על שולחן ארוך בסגנון שוק ישראלי — עשיר, צבעוני ומגוון. השולחן כולל שניצל בלחמניות, המבורגר בלחמניות, 9 סוגי מטוגנים, 8 סלטים טריים, פירות העונה וקינוחי בוטיק. הכול מוכן טרי ביום האירוע ומוגש בסגנון שוק שמשדר שפע ונדיבות. <a href="/tafrit/" class="text-brand-600 hover:underline">לתפריט המלא</a>.' },
  { question: 'כמה עולה שולחן שוק?', answer: '80-95 ₪ לאורח, לפי כמות הסועדים: 20 סועדים — 95 ₪, 30 — 90 ₪, 40 — 85 ₪, 50 — 80 ₪. המחיר כולל תפריט מלא + הכנה + הגעה + סידור + הגשה + פינוי. <a href="/mehirim/" class="text-brand-600 hover:underline">למחירון המלא</a>.' },
  { question: 'מה כולל שולחן שוק?', answer: 'התפריט הסטנדרטי כולל: שניצל פריך בלחמניות + המבורגר בלחמניות + 9 סוגי מטוגנים (צ\'יפס, צ\'יפס בטטה, טבעות בצל, סיגרים בשר, פסטלים, נקניקיות, כדורי פירה, פלאפל, קובה) + 8 סלטים (חומוס, טחינה, כרוב סגול, מטבוחה, ירקות, סלט ישראלי, כרוב, עלי בייבי) + פירות העונה + קינוחי בוטיק.' },
  { question: 'לאילו אירועים מתאים שולחן שוק?', answer: 'שולחן שוק מתאים לכל אירוע: <a href="/yom-huledet/" class="text-brand-600 hover:underline">ימי הולדת</a>, <a href="/bar-mitzva/" class="text-brand-600 hover:underline">בר/בת מצווה</a>, <a href="/hatuna/" class="text-brand-600 hover:underline">חתונות</a>, <a href="/mesibat-ravakot/" class="text-brand-600 hover:underline">מסיבות רווקות</a>, <a href="/hina/" class="text-brand-600 hover:underline">חינות</a>, <a href="/eruey-hevra/" class="text-brand-600 hover:underline">אירועי חברה</a>, <a href="/shabat/" class="text-brand-600 hover:underline">שבתות</a> וחגים.' },
  { question: 'מה המינימום להזמנה?', answer: 'המינימום הוא 20 אורחים לכל סוגי השולחנות. לאירועים קטנים יותר — צרו קשר ונמצא פתרון.' },
  { question: 'האם הכול כשר למהדרין?', answer: 'כן. כל השולחנות שלנו כשרים למהדרין — תעודת כשרות, חומרי גלם מהודרים, השגחה צמודה, הפרדה מלאה בין בשרי לחלבי. הכשרות כלולה ללא תוספת מחיר. <a href="/kasher/" class="text-brand-600 hover:underline">לפרטים על הכשרות</a>.' },
  { question: 'אתם עובדים בכל הארץ?', answer: 'כן! אנחנו מספקים שירות שולחן שוק בכל רחבי ישראל — <a href="/tel-aviv/" class="text-brand-600 hover:underline">תל אביב והמרכז</a>, <a href="/haifa/" class="text-brand-600 hover:underline">חיפה והצפון</a>, <a href="/yerushalayim/" class="text-brand-600 hover:underline">ירושלים</a>, <a href="/beer-sheva/" class="text-brand-600 hover:underline">באר שבע והדרום</a> ועוד. באזור המרכז ללא תוספת נסיעה.' },
  { question: 'כמה זמן מראש צריך להזמין?', answer: 'מומלץ להזמין שבוע-שבועיים מראש. בעונות עמוסות (קיץ, חגים, עונות בר מצווה) — 2-3 שבועות מראש. לפעמים יש זמינות גם בהתראה קצרה יותר — שווה לנסות.' },
  { question: 'אילו סוגי שולחנות יש?', answer: 'מציעים מגוון שולחנות: <a href="/basari/" class="text-brand-600 hover:underline">בשרי</a>, <a href="/halavi/" class="text-brand-600 hover:underline">חלבי</a>, <a href="/hamburger/" class="text-brand-600 hover:underline">המבורגר</a>, <a href="/schnitzel/" class="text-brand-600 hover:underline">שניצל</a>, <a href="/tzimhoni/" class="text-brand-600 hover:underline">צמחוני</a>, <a href="/metugganim/" class="text-brand-600 hover:underline">מטוגנים</a> ו<a href="/kinuchim/" class="text-brand-600 hover:underline">קינוחים</a>. אפשר לשלב כמה סוגים באותו אירוע.' },
  { question: 'אפשר להתאים את התפריט?', answer: 'בהחלט! ניתן להתאים לאלרגיות (ללא גלוטן, ללא אגוזים), העדפות תזונתיות (צמחוני, טבעוני), ולהוסיף תוספות מיוחדות. שרית בונה תפריט מותאם לכל אירוע.' },
  { question: 'מה כלול בשירות מלבד האוכל?', answer: 'הכול: ייעוץ אישי ובניית תפריט, הכנה טרייה ביום האירוע, הגעה למקום (כל הארץ), סידור ועיצוב השולחן, הגשה מקצועית, פינוי וניקיון. אתם רק צריכים מקום ושולחן.' },
  { question: 'אפשר לשלב שולחן בשרי וחלבי באותו אירוע?', answer: 'כן! עם הפרדת כשרות מלאה — כלים נפרדים, אזורי הגשה נפרדים, שולחנות נפרדים. שילוב פופולרי בחתונות: חלבי כקבלת פנים + בשרי כארוחה ראשית.' },
  { question: 'איך מזמינים?', answer: 'פשוט: 055-432-7900 (טלפון/וואטסאפ) או טופס באתר. שרית חוזרת תוך שעה עם הצעת מחיר מותאמת.' },
];
---

<BaseLayout
  title="שאלות נפוצות — שולחן שוק | מחירים, כשרות, תפריט, אזורי שירות"
  description="שאלות נפוצות על שולחן שוק: כמה עולה, מה כלול, האם כשר למהדרין, לאילו אירועים מתאים ועוד. כל התשובות במקום אחד."
>
  <section class="py-12">
    <div class="max-w-4xl mx-auto px-4">
      <Breadcrumbs items={[{ label: 'שאלות נפוצות' }]} />
      <h1 class="text-3xl md:text-4xl font-heading text-dark mb-3 text-center">שאלות נפוצות על שולחן שוק</h1>
      <p class="text-muted text-center mb-8">כל מה שצריך לדעת לפני שמזמינים — מחירים, תפריט, כשרות, אזורי שירות ועוד</p>
    </div>
  </section>
  <FAQ items={faqItems} title="" />
  <CTASection
    title="לא מצאתם תשובה?"
    subtitle="צרו קשר ושרית תשמח לעזור"
    phone="055-432-7900"
  />
</BaseLayout>
